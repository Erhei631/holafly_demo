<view class="page" style="padding-top: {{statusBarHeight}}px; padding-bottom: {{safeBottom}}px;">
  <view class="subpage-nav">
    <view class="subpage-nav__back" bindtap="onBack">
      <text class="subpage-nav__back-icon">‹</text>
    </view>
    <text class="subpage-nav__title">安装教程</text>
    <view class="subpage-nav__spacer" />
  </view>

  <scroll-view class="install-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="install-stack">
      <view class="install-segment">
        <view
          class="install-segment__item {{platform === 'ios' ? 'install-segment__item--active' : ''}}"
          data-platform="ios"
          bindtap="onPlatformChange"
        >
          <text>iPhone</text>
        </view>
        <view
          class="install-segment__item {{platform === 'android' ? 'install-segment__item--active' : ''}}"
          data-platform="android"
          bindtap="onPlatformChange"
        >
          <text>Android</text>
        </view>
      </view>

      <view class="install-card">
        <text class="install-card__title">前置说明</text>
        <view class="install-preface">
          <view wx:for="{{preface}}" wx:key="id" class="install-preface__item">
            <view class="install-preface__icon-wrap">
              <image class="install-preface__icon" src="{{item.icon}}" mode="aspectFit" />
            </view>
            <text class="install-preface__text">{{item.text}}</text>
          </view>
        </view>
      </view>

      <view class="install-card">
        <text class="install-card__title">具体步骤</text>
        <view class="install-steps">
          <view wx:for="{{activeSteps}}" wx:key="id" class="install-step">
            <text class="install-step__text">{{item.text}}</text>
            <image
              wx:if="{{item.image}}"
              class="install-step__image {{item.imageCompact ? 'install-step__image--order' : ''}}"
              src="{{item.image}}"
              mode="{{item.imageMode || 'widthFix'}}"
            />
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
