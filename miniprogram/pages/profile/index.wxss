.profile-page {
  position: relative;
  background: var(--color-bg-base);
}

.profile-map {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 280rpx;
  pointer-events: none;
}

.profile-scroll {
  position: relative;
  z-index: 1;
}

.profile-user {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 48rpx 48rpx 0;
  margin-top: 24rpx;
}

.profile-user__avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  display: block;
}

.profile-user__phone {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.profile-menu {
  margin-top: 48rpx;
}

.profile-menu__item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 24rpx 64rpx;
  box-sizing: border-box;
  background: var(--color-bg-base);
}

.profile-menu__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.profile-menu__icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-menu__icon {
  width: 32rpx;
  height: 32rpx;
  display: block;
}

.profile-menu__label {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.profile-menu__arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}
