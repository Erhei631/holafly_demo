<view class="detail-page" style="padding-top: {{statusBarHeight}}px;">
  <view class="detail-nav">
    <view class="detail-nav__back" bindtap="onBack" aria-label="返回">
      <image class="detail-nav__back-icon" src="/images/detail/nav-back.svg" mode="aspectFit" />
    </view>
    <view class="detail-nav__right">
      <view class="nav-capsule nav-capsule--menu">
        <image class="nav-capsule__icon nav-capsule__icon--sm" src="/images/detail/nav-share.svg" mode="aspectFit" />
        <image class="nav-capsule__sep" src="/images/detail/nav-divider.svg" mode="aspectFit" />
        <image class="nav-capsule__icon nav-capsule__icon--sm" src="/images/detail/nav-close.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <scroll-view
    class="detail-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    style="padding-bottom: calc(176rpx + {{safeBottom}}px);"
  >
    <view class="detail-content">
      <view class="hero-card">
        <image class="hero-card__bg" src="{{plan.hero}}" mode="aspectFill" />
        <view class="hero-card__body">
          <view class="hero-card__title-row">
            <image class="hero-card__flag" src="{{plan.flag}}" mode="aspectFill" />
            <text class="hero-card__title">{{plan.title}}</text>
          </view>
          <view class="hero-card__tags">
            <view wx:for="{{plan.features}}" wx:key="id" class="hero-card__tag">
              <image class="hero-card__tag-icon" src="{{item.icon}}" mode="aspectFit" />
              <text class="hero-card__tag-text">{{item.label}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="config-card">
        <view class="config-card__wrap">
          <view class="config-card__inner">
            <view class="config-section config-section--days">
              <view class="config-section__head">
                <view class="config-section__label-wrap">
                  <image class="config-section__icon" src="/images/detail/icon-calendar.svg" mode="aspectFit" />
                  <text class="config-section__label">使用天数</text>
                </view>
                <view class="config-section__badge">
                  <text>多天更划算</text>
                </view>
              </view>
              <view class="day-grid">
                <view
                  wx:for="{{dayChipOptionsRow1}}"
                  wx:key="days"
                  class="day-chip {{!isCustomDays && selectedDays === item.days ? 'day-chip--active' : ''}}"
                  data-days="{{item.days}}"
                  bindtap="onDaySelect"
                >
                  <text class="day-chip__label">{{item.days}}天</text>
                </view>
              </view>
              <view class="day-grid">
                <view
                  wx:for="{{dayChipOptionsRow2}}"
                  wx:key="days"
                  class="day-chip {{!isCustomDays && selectedDays === item.days ? 'day-chip--active' : ''}}"
                  data-days="{{item.days}}"
                  bindtap="onDaySelect"
                >
                  <text class="day-chip__label">{{item.days}}天</text>
                </view>
              </view>
              <view class="day-custom {{isCustomDays ? 'day-custom--active' : ''}}" bindtap="onCustomDaysTap">
                <image class="day-custom__icon" src="{{isCustomDays ? '/images/detail/icon-calendar-edit-active.svg' : '/images/detail/icon-calendar-edit.svg'}}" mode="aspectFit" />
                <text class="day-custom__text">{{customDaysLabel || '自定义'}}</text>
              </view>
            </view>

            <view class="config-section">
              <view class="config-section__label-wrap config-section__label-wrap--solo">
                <image class="config-section__icon" src="/images/detail/icon-esim.svg" mode="aspectFit" />
                <text class="config-section__label">eSIM数量</text>
              </view>
              <view class="qty-stepper">
                <view
                  class="qty-stepper__btn {{quantity <= 1 ? 'qty-stepper__btn--disabled' : ''}}"
                  bindtap="onQtyMinus"
                >
                  <image class="qty-stepper__icon" src="/images/detail/icon-minus.svg" mode="aspectFit" />
                </view>
                <text class="qty-stepper__value">{{quantity}}</text>
                <view
                  class="qty-stepper__btn qty-stepper__btn--plus {{quantity >= maxQuantity ? 'qty-stepper__btn--disabled' : ''}}"
                  bindtap="onQtyPlus"
                >
                  <image class="qty-stepper__icon" src="/images/detail/icon-plus.svg" mode="aspectFit" />
                </view>
              </view>
            </view>
          </view>

          <view class="config-card__promo">
            <view class="config-card__promo-left">
              <view class="config-card__promo-daily">
                <text class="config-card__promo-daily-label">限时补贴低至日均</text>
                <text class="config-card__promo-daily-currency">¥</text>
                <text class="config-card__promo-daily-amount">{{dailyAvgLabel}}</text>
                <text class="config-card__promo-daily-unit">/天</text>
              </view>
              <view class="config-card__promo-tags">
                <view class="config-card__promo-tag">
                  <text>原价¥{{originalDaily}}起</text>
                </view>
                <view class="config-card__promo-tag">
                  <text>{{saveLabel}}</text>
                </view>
              </view>
            </view>
            <view class="config-card__promo-countdown">
              <text class="config-card__promo-countdown-label">距离优惠结束</text>
              <view class="config-card__promo-timer">
                <text class="config-card__promo-timer-box">{{countdownH}}</text>
                <text class="config-card__promo-timer-sep">:</text>
                <text class="config-card__promo-timer-box">{{countdownM}}</text>
                <text class="config-card__promo-timer-sep">:</text>
                <text class="config-card__promo-timer-box">{{countdownS}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="compat-card" bindtap="onCompatCardTap">
        <image class="compat-card__icon" src="{{plan.compatCard.icon}}" mode="aspectFit" />
        <view class="compat-card__content">
          <text class="compat-card__title">{{plan.compatCard.title}}</text>
          <text class="compat-card__subtitle">{{plan.compatCard.subtitle}}</text>
        </view>
        <image class="compat-card__arrow" src="/images/detail/icon-arrow-right.svg" mode="aspectFit" />
      </view>

      <view class="panel panel--promise">
        <text class="panel__title panel__title--inline">Holafly服务承诺</text>
        <view class="promise-strip">
          <view class="promise-grid">
            <view wx:for="{{plan.servicePromises}}" wx:key="id" class="promise-item">
              <image class="promise-item__icon" src="{{item.icon}}" mode="aspectFit" />
              <view class="promise-item__text">
                <text class="promise-item__line">{{item.lines[0]}}</text>
                <text class="promise-item__line">{{item.lines[1]}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="panel panel--apps">
        <image class="panel__deco panel__deco--apps" src="/images/detail/app-deco.png" mode="aspectFit" />
        <view class="panel__intro">
          <text class="panel__title panel__title--inline">畅连国内外APP</text>
          <text class="panel__subtitle">{{plan.appIntro}}</text>
        </view>
        <view class="panel__divider" />
        <view class="panel__apps-body">
          <block wx:for="{{appSections}}" wx:key="id">
            <text class="app-section__title">{{item.title}}</text>
            <view wx:for="{{item.rows}}" wx:for-item="row" wx:key="*this" class="app-row">
              <view wx:for="{{row}}" wx:for-item="app" wx:key="id" class="app-tile">
                <image class="app-tile__icon" src="{{app.icon}}" mode="aspectFit" />
                <view class="app-tile__text">
                  <text class="app-tile__name">{{app.name}}</text>
                  <text class="app-tile__subtitle">{{app.subtitle}}</text>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>

      <view class="reviews-card">
        <view class="reviews-card__header" bindtap="onReviewsAllTap">
          <view class="reviews-card__brand">
            <image class="reviews-card__logo" src="/images/home/trustpilot-logo.svg" mode="aspectFit" />
            <text class="reviews-card__count">来自 {{plan.reviewSummary.total}} 位用户评价</text>
          </view>
          <view class="reviews-card__rating">
            <text class="reviews-card__score">{{plan.reviewSummary.rating}}</text>
            <text class="reviews-card__max">/5</text>
            <image class="reviews-card__arrow" src="/images/home/icon-arrow-right.svg" mode="aspectFit" />
          </view>
        </view>
        <view class="reviews-card__divider" />
        <view class="reviews-list">
          <view wx:for="{{plan.reviews}}" wx:key="id" class="review-item">
            <view class="review-item__top">
              <text class="review-item__name">{{item.name}}</text>
              <view class="review-item__badge">
                <text class="review-item__badge-text">{{item.rating}}</text>
              </view>
            </view>
            <text class="review-item__text">{{item.text}}</text>
            <text class="review-item__meta">{{item.meta}}</text>
          </view>
        </view>
      </view>

      <view class="panel">
        <view class="panel__head">
          <text class="panel__title panel__title--inline">使用方法</text>
          <view class="panel__link" bindtap="onUsageGuideTap">
            <text>查看完整教程</text>
            <image class="panel__link-icon" src="/images/detail/icon-arrow-right.svg" mode="aspectFit" />
          </view>
        </view>
        <view class="usage-steps">
          <view class="usage-steps__connector usage-steps__connector--1" />
          <view class="usage-steps__connector usage-steps__connector--2" />
          <view wx:for="{{plan.usageSteps}}" wx:key="id" class="usage-step">
            <view class="usage-step__icon-wrap">
              <image class="usage-step__icon" src="{{item.icon}}" mode="aspectFit" />
            </view>
            <text class="usage-step__label">{{item.label}}</text>
          </view>
        </view>
      </view>

      <view class="panel">
        <text class="panel__title">网络服务</text>
        <view class="network-block">
          <view class="network-block__head">
            <image class="network-block__icon" src="/images/detail/icon-carrier.svg" mode="aspectFit" />
            <text class="network-block__label">网络运营商</text>
          </view>
          <view class="network-block__carriers">
            <image
              wx:for="{{plan.networkCarriers}}"
              wx:key="id"
              class="network-block__carrier-logo network-block__carrier-logo--{{item.id}}"
              style="width: {{item.width}}rpx;"
              src="{{item.icon}}"
              mode="aspectFit"
            />
          </view>
        </view>
        <view class="network-block">
          <view class="network-block__head">
            <image class="network-block__icon" src="/images/detail/icon-network.svg" mode="aspectFit" />
            <text class="network-block__label">网速</text>
          </view>
          <text class="network-block__text">{{plan.networkSpeedText}}</text>
        </view>
      </view>

      <view class="panel panel--last">
        <text class="panel__title">常见问题</text>
        <view class="faq-list faq-list--simple">
          <view
            wx:for="{{plan.faqItems}}"
            wx:key="id"
            class="faq-item faq-item--simple {{expandedFaqId === item.id ? 'faq-item--open' : ''}}"
          >
            <view class="faq-item__row" data-id="{{item.id}}" bindtap="onFaqTap">
              <text class="faq-item__title">{{item.title}}</text>
              <image
                class="faq-item__arrow {{expandedFaqId === item.id ? 'faq-item__arrow--open' : ''}}"
                src="/images/detail/icon-arrow-right.svg"
                mode="aspectFit"
              />
            </view>
            <text wx:if="{{item.answer && expandedFaqId === item.id}}" class="faq-item__answer">{{item.answer}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view
    class="compat-sheet-mask {{showCompatSheet ? 'compat-sheet-mask--show' : ''}}"
    bindtap="onCloseCompatSheet"
    catchtouchmove="noop"
  />
  <view
    class="compat-sheet {{showCompatSheet ? 'compat-sheet--show' : ''}}"
    style="padding-bottom: {{safeBottom + 24}}px;"
    catchtap="noop"
    catchtouchmove="noop"
  >
      <view class="compat-sheet__handle-wrap">
        <view class="compat-sheet__handle"></view>
      </view>
      <view class="compat-sheet__header">
        <text class="compat-sheet__title">检查我的手机是否支持 eSIM</text>
        <view class="compat-sheet__close" bindtap="onCloseCompatSheet" aria-label="关闭">
          <image class="compat-sheet__close-icon" src="/images/compat/close.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="compat-sheet__section">
        <text class="compat-step-label">1. 您的手机是哪个版本</text>
        <view class="compat-version-row">
          <view
            wx:for="{{compatVersions}}"
            wx:key="id"
            class="compat-version compat-version--{{item.id}} {{compatVersion === item.id ? 'compat-version--active' : ''}}"
            data-version="{{item.id}}"
            bindtap="onCompatVersionTap"
          >
            <image class="compat-version__icon" src="{{item.icon}}" mode="aspectFill" />
            <view class="compat-version__text">
              <text class="compat-version__title">{{item.title}}</text>
              <text class="compat-version__subtitle">{{item.subtitle}}</text>
            </view>
          </view>
        </view>
      </view>
      <scroll-view class="compat-sheet__body" scroll-y enhanced show-scrollbar="{{false}}">
          <text class="compat-step-label">2. 选择查询方式</text>
          <view class="compat-segment">
            <view
              wx:for="{{compatMethods}}"
              wx:key="id"
              class="compat-segment__item {{compatMethod === item.id ? 'compat-segment__item--active' : ''}}"
              data-method="{{item.id}}"
              bindtap="onCompatMethodTap"
            >
              <text>{{item.label}}</text>
            </view>
          </view>
          <view wx:if="{{compatMethod === 'model'}}" class="compat-model-panel">
            <view class="compat-search">
              <image class="compat-search__icon" src="/images/compat/search.svg" mode="aspectFit" />
              <input
                class="compat-search__input"
                placeholder="搜索手机品牌或型号"
                placeholder-class="compat-search__placeholder"
                value="{{compatSearch}}"
                bindinput="onCompatSearchInput"
              />
            </view>
            <view class="compat-models">
              <view class="compat-device-block">
                <text class="compat-sheet__label">您的机型</text>
                <view class="compat-model">
                  <text class="compat-model__name">{{compatDevice.name}}</text>
                  <view wx:if="{{compatDevice.supported}}" class="compat-model__badge">
                    <image class="compat-model__check" src="/images/compat/check.svg" mode="aspectFit" />
                    <text>支持</text>
                  </view>
                </view>
              </view>
              <view class="compat-model__divider" />
              <text class="compat-sheet__label">热门机型</text>
              <block wx:for="{{filteredCompatModels}}" wx:key="id">
                <view class="compat-model">
                  <text class="compat-model__name">{{item.name}}</text>
                  <view wx:if="{{item.supported}}" class="compat-model__badge">
                    <image class="compat-model__check" src="/images/compat/check.svg" mode="aspectFit" />
                    <text>支持</text>
                  </view>
                </view>
                <view wx:if="{{index < filteredCompatModels.length - 1}}" class="compat-model__divider" />
              </block>
            </view>
          </view>
          <view wx:else class="compat-dial">
            <text class="compat-dial__code">*#06#</text>
            <text class="compat-dial__hint">{{compatDialHint}}</text>
          </view>
      </scroll-view>
  </view>

  <view wx:if="{{showDateRangeSheet}}" class="date-sheet-mask" bindtap="onCloseDateSheet">
    <view class="date-sheet" catchtap="noop">
      <view class="date-sheet__header">
        <text class="date-sheet__title">选择出行日期</text>
        <view class="date-sheet__close" bindtap="onCloseDateSheet" aria-label="关闭">×</view>
      </view>
      <view class="cal-weekdays">
        <text
          wx:for="{{weekdayLabels}}"
          wx:key="*this"
          class="cal-weekdays__item {{index === 0 || index === 6 ? 'cal-weekdays__item--weekend' : ''}}"
        >{{item}}</text>
      </view>
      <scroll-view class="date-sheet__calendar" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:for="{{calendarMonths}}" wx:key="key" class="cal-month">
          <text class="cal-month__title">{{item.label}}</text>
          <view class="cal-month__grid">
            <view wx:for="{{item.rows}}" wx:for-item="row" wx:key="key" class="cal-week">
              <block wx:for="{{row.cells}}" wx:for-item="cell" wx:key="key">
                <view wx:if="{{cell.type === 'empty'}}" class="cal-day cal-day--empty" />
                <view
                  wx:else
                  class="cal-day{{cell.rangeState ? ' cal-day--' + cell.rangeState : ''}}{{cell.disabled ? ' cal-day--disabled' : ''}}"
                  data-date="{{cell.dateStr}}"
                  data-disabled="{{cell.disabled ? 1 : 0}}"
                  bindtap="onCalendarDayTap"
                >
                  <text class="cal-day__num">{{cell.day}}</text>
                  <text wx:if="{{cell.isToday}}" class="cal-day__tag">今天</text>
                </view>
              </block>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="date-sheet__footer">
        <view class="date-sheet__summary">
          <view class="date-sheet__summary-dates">
            <text>去: {{startFooterLabel}}</text>
            <text>返: {{endFooterLabel}}</text>
          </view>
          <text wx:if="{{customDaysPreview}}" class="date-sheet__summary-days">共 {{customDaysPreview}} 天</text>
          <text wx:elif="{{startDate && !endDate}}" class="date-sheet__summary-days">请选择返回日期</text>
        </view>
        <button class="date-sheet__confirm btn-primary" bindtap="onConfirmDateRange">确定</button>
      </view>
    </view>
  </view>

  <view class="detail-footer" style="padding-bottom: {{safeBottom}}px;">
    <view class="detail-footer__inner">
      <view class="detail-footer__support" bindtap="onSupportTap">
        <image class="detail-footer__support-icon" src="/images/detail/footer-support.svg" mode="aspectFit" />
        <text class="detail-footer__support-label">客服</text>
      </view>
      <view class="detail-footer__price">
        <text class="detail-footer__currency">¥</text>
        <text class="detail-footer__amount">{{dailyAvgLabel}}</text>
        <text class="detail-footer__meta">/天</text>
      </view>
      <button class="detail-footer__cta btn-primary" bindtap="onCheckout">去结算</button>
    </view>
  </view>
</view>
