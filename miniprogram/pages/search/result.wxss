.detail-page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: linear-gradient(
    127deg,
    #c8ebfe 2.09%,
    #fcecfc 15.98%,
    var(--rose-50) 35.2%,
    var(--color-bg-base) 54.59%
  );
}

/* —— 导航 —— */
.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 14rpx 0 14rpx;
  flex-shrink: 0;
}

.detail-nav__right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-capsule {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #dedede;
  border-radius: 30rpx;
  box-sizing: border-box;
}

.detail-nav__back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.detail-nav__back-icon {
  width: 18rpx;
  height: 33rpx;
  flex-shrink: 0;
}

.nav-capsule--support {
  width: 60rpx;
  padding: 0;
}

.nav-capsule--menu {
  width: 166rpx;
  gap: 0;
  padding: 0 20rpx;
}

.nav-capsule__icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-capsule__icon--sm {
  width: 28rpx;
  height: 28rpx;
}

.nav-capsule__sep {
  width: 2rpx;
  height: 26rpx;
  margin: 0 16rpx;
}

.detail-scroll {
  flex: 1;
  height: 0;
}

.detail-content {
  padding: 8rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* —— 头图卡片 —— */
.hero-card {
  position: relative;
  overflow: hidden;
  min-height: 244rpx;
  border-radius: 48rpx;
  background: var(--color-bg-base);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
}

.hero-card__bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hero-card__body {
  position: relative;
  z-index: 1;
  padding: 32rpx;
}

.hero-card__title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 4rpx;
}

.hero-card__flag {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.hero-card__title {
  font-size: 40rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.hero-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.hero-card__tag {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 16rpx;
  background: var(--rose-50);
  border-radius: 12rpx;
}

.hero-card__tag-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.hero-card__tag-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-primary);
  line-height: 1.33;
}

/* —— 套餐配置卡 —— */
.config-card {
  padding: 20rpx;
  border-radius: 48rpx;
  background: var(--blue-100);
  border: 2rpx solid var(--color-secondary);
  box-shadow: 0 30rpx 40rpx #ffece1;
}

.config-card__inner {
  padding: 32rpx 32rpx 24rpx;
  background: var(--color-bg-base);
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.config-section__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.config-section--days {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.config-section--days .config-section__head {
  margin-bottom: 0;
}

.config-section__label-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.config-section__label-wrap--solo {
  margin-bottom: 24rpx;
}

.config-section__icon {
  display: block;
  width: 40rpx;
  height: 40rpx;
  max-width: 40rpx;
  max-height: 40rpx;
  flex-shrink: 0;
}

.config-section__label {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.47;
}

.config-section__badge {
  padding: 8rpx 12rpx;
  background: var(--green-100);
  border-radius: 8rpx;
}

.config-section__badge text {
  font-size: 24rpx;
  color: var(--green-700);
  line-height: 1.33;
}

.day-grid {
  display: flex;
  gap: 16rpx;
}

.day-chip {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 20rpx 12rpx;
  box-sizing: border-box;
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  border-radius: 20rpx;
}

.day-chip__label {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  line-height: 48rpx;
  white-space: nowrap;
}

.day-chip__price {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-primary);
  line-height: 32rpx;
  white-space: nowrap;
}

.day-chip__badge {
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  padding: 4rpx 8rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, rgba(230, 72, 92, 0.25) 0%, rgba(255, 239, 239, 0) 100%);
  white-space: nowrap;
}

.day-chip--active {
  background: var(--rose-50);
  border-color: var(--color-primary);
}

.day-chip--active .day-chip__label {
  color: var(--color-primary);
}

.day-custom {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  box-sizing: border-box;
  background: var(--neutral-100);
  border: 2rpx solid var(--color-border-base);
  border-radius: 20rpx;
}

.day-custom__icon {
  width: 40rpx;
  height: 40rpx;
}

.day-custom__text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.day-custom--active {
  background: var(--rose-50);
  border-color: var(--color-primary);
}

.day-custom--active .day-custom__text {
  color: var(--color-primary);
}

.date-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.date-sheet {
  width: 100%;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-base);
  border-radius: 32rpx 32rpx 0 0;
  box-sizing: border-box;
}

.date-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.date-sheet__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.date-sheet__close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
  color: var(--color-text-tertiary);
}

.date-sheet__body {
  margin-bottom: 32rpx;
}

.date-picker-block + .date-picker-block {
  margin-top: 24rpx;
}

.date-picker__label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.date-picker__wheel {
  width: 100%;
  height: 360rpx;
}

.date-picker__item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  line-height: 40rpx;
}

.date-picker__indicator {
  height: 80rpx;
  border-top: 1rpx solid var(--color-border-base);
  border-bottom: 1rpx solid var(--color-border-base);
}

.date-sheet__hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

.date-sheet__confirm {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.date-sheet__confirm::after {
  border: none;
}

.qty-stepper {
  display: flex;
  align-items: stretch;
  height: 88rpx;
  border: 2rpx solid var(--color-border-base);
  border-radius: 20rpx;
  overflow: hidden;
}

.qty-stepper__btn {
  width: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-base);
  border-right: 2rpx solid var(--color-border-base);
}

.qty-stepper__btn--plus {
  border-right: none;
  border-left: 2rpx solid var(--color-border-base);
}

.qty-stepper__btn--disabled {
  opacity: 0.35;
}

.qty-stepper__icon {
  width: 48rpx;
  height: 48rpx;
}

.qty-stepper__value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.price-summary__divider {
  height: 1rpx;
  background: var(--color-divider);
  margin-bottom: 24rpx;
}

.price-summary__row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.price-summary__total {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price-summary__value {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.price-summary__total-label {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.price-summary__currency {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.price-summary__amount {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-primary);
  line-height: 1;
}

.price-summary__side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.price-summary__daily-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price-summary__daily-label,
.price-summary__daily-unit {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.price-summary__daily-currency {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.price-summary__daily-amount {
  font-size: 60rpx;
  font-weight: 600;
  color: var(--color-primary);
  line-height: 1;
}

.price-summary__promo-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 8rpx;
}

.price-summary__original {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-decoration: line-through;
  opacity: 0.7;
}

.price-summary__save {
  padding: 4rpx 8rpx;
  background: var(--rose-100);
  border-radius: 8rpx;
}

.price-summary__save text {
  font-size: 24rpx;
  color: var(--color-primary);
}

/* —— 通用面板 —— */
.panel {
  padding: 32rpx;
  background: var(--color-bg-base);
  border-radius: 48rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
}

.panel--last {
  margin-bottom: 8rpx;
}

.panel__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel__title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.panel__title--inline {
  margin-bottom: 0;
}

.panel__link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-size-body);
  color: var(--color-text-tertiary);
}

.panel__link-icon {
  width: 32rpx;
  height: 32rpx;
}

.panel__divider {
  height: 1rpx;
  background: var(--color-divider);
  margin: 24rpx 0;
}

.review-card {
  padding: 20rpx 32rpx;
  background: var(--neutral-100);
  border-radius: 32rpx;
}

.review-card + .review-card {
  margin-top: 24rpx;
}

.review-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.review-card__name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.review-card__badge {
  padding: 4rpx 8rpx;
  background: var(--rose-100);
  border-radius: 8rpx;
}

.review-card__badge-text {
  font-family: var(--font-family-mono);
  font-size: var(--font-size-note);
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: var(--color-primary);
  line-height: 1.33;
}

.review-card__text {
  display: block;
  margin-top: 16rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  line-height: 1.47;
}

.review-card__meta {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.faq-item {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 24rpx 24rpx 24rpx 32rpx;
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  border-radius: 20rpx;
}

.faq-item__row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

.faq-item--highlight {
  padding: 36rpx 24rpx 40rpx 16rpx;
  border-color: rgba(255, 255, 255, 0.9);
  background: linear-gradient(139deg, var(--blue-50) 11.21%, var(--green-50) 89.26%);
}

.faq-item--open {
  padding-bottom: 28rpx;
}

.faq-item__icon {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.faq-item__content {
  flex: 1;
  min-width: 0;
}

.faq-item__title {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.faq-item--highlight .faq-item__title {
  font-size: 32rpx;
  font-weight: 500;
  line-height: 48rpx;
}

.faq-item__subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.33;
}

.faq-item__arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  transition: transform 0.2s ease;
}

.faq-item__arrow--open {
  transform: rotate(90deg);
}

.faq-item__answer {
  display: block;
  margin-top: 16rpx;
  padding-left: 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 40rpx;
}

.compat-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 110;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.compat-sheet-mask--show {
  opacity: 1;
  pointer-events: auto;
}

.compat-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 111;
  width: 100%;
  height: 82vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg-base);
  border-radius: 48rpx 48rpx 0 0;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
  pointer-events: none;
  will-change: transform;
}

.compat-sheet--show {
  transform: translateY(0);
  pointer-events: auto;
}

.compat-sheet__handle-wrap {
  display: flex;
  justify-content: center;
  padding: 8rpx 0 16rpx;
}

.compat-sheet__handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: var(--color-border-base);
}

.compat-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx;
  min-height: 104rpx;
  box-sizing: border-box;
}

.compat-sheet__title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.compat-sheet__close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.compat-sheet__close-icon {
  width: 56rpx;
  height: 56rpx;
}

.compat-sheet__scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.compat-sheet__section {
  padding: 0 40rpx 16rpx;
}

.compat-sheet__body {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 32rpx 40rpx 0;
}

.compat-sheet__label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 32rpx;
}

.compat-version-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.compat-version {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  border-radius: 32rpx;
  box-sizing: border-box;
}

.compat-version--active {
  background: var(--rose-50);
  border-color: var(--color-primary);
}

.compat-version__icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.compat-version__text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.compat-version__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.compat-version__subtitle {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 32rpx;
}

.compat-segment {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  background: var(--neutral-100);
  border-radius: 24rpx;
}

.compat-segment__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.compat-segment__item--active {
  background: var(--color-bg-base);
  box-shadow: 0 4rpx 16rpx -8rpx rgba(0, 0, 0, 0.2);
}

.compat-search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: var(--neutral-100);
  border-radius: 48rpx;
}

.compat-search__icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.compat-search__input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.compat-search__placeholder {
  color: var(--color-text-secondary);
}

.compat-models {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.compat-model {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--neutral-100);
}

.compat-model:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.compat-model__name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.compat-model__badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  background: var(--green-100);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: var(--green-700);
  line-height: 32rpx;
  flex-shrink: 0;
}

.compat-model__check {
  width: 28rpx;
  height: 28rpx;
}

.compat-dial {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx 24rpx;
  background: var(--neutral-100);
  border-radius: 32rpx;
}

.compat-dial__code {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
  letter-spacing: 2rpx;
}

.compat-dial__hint {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 40rpx;
  text-align: center;
}

.info-block {
  padding: 24rpx 32rpx;
  background: var(--neutral-100);
  border-radius: 20rpx;
}

.info-block + .info-block {
  margin-top: 16rpx;
}

.info-block__head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-block__icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.info-block__label {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.info-block__text {
  display: block;
  margin-top: 16rpx;
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  line-height: 1.43;
}

.app-row {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--neutral-100);
  border-radius: 20rpx;
  overflow: hidden;
}

.app-row__item {
  position: relative;
  flex-shrink: 0;
  width: 92rpx;
  height: 92rpx;
  margin-right: -32rpx;
  border-radius: var(--radius-full);
  border: 4rpx solid var(--color-bg-base);
  background: var(--color-bg-base);
  overflow: hidden;
}

.app-row__item:last-child {
  margin-right: 0;
}

.app-row__icon {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 64%;
  height: 64%;
  transform: translate(-50%, -50%);
}

.promise-grid {
  display: flex;
  justify-content: space-between;
  width: 100%;
}

.promise-item {
  width: 148rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.promise-item__icon {
  width: 64rpx;
  height: 64rpx;
}

.promise-item__text {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 32rpx;
  text-align: center;
}

.promise-item__line {
  line-height: 32rpx;
}

/* —— 底部结算栏 —— */
.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(248, 248, 248, 0.8);
  backdrop-filter: blur(30px);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.detail-footer__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 32rpx 40rpx 32rpx;
}

.detail-footer__price {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  min-width: 200rpx;
}

.detail-footer__currency {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-primary);
  line-height: 1.33;
}

.detail-footer__amount {
  font-size: 48rpx;
  font-weight: 500;
  color: var(--color-primary);
  line-height: 1;
  margin-left: 4rpx;
}

.detail-footer__meta {
  margin-left: 12rpx;
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.detail-footer__cta {
  flex: 1;
  max-width: 492rpx;
  margin: 0 !important;
  height: 96rpx !important;
  border-radius: 20rpx !important;
  font-size: 32rpx !important;
  font-weight: 500 !important;
  box-shadow: 0 20rpx 40rpx rgba(57, 224, 57, 0.35);
}
