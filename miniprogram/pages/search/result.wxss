.detail-page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: linear-gradient(
    151.84deg,
    #c8ebfe 2.09%,
    #fcecfc 15.98%,
    var(--rose-50) 35.2%,
    var(--color-bg-base) 54.59%
  );
}

/* —— 导航 —— */
.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 14rpx 0 14rpx;
  flex-shrink: 0;
}

.detail-nav__right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-capsule {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #dedede;
  border-radius: 30rpx;
  box-sizing: border-box;
}

.detail-nav__back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.detail-nav__back-icon {
  width: 18rpx;
  height: 33rpx;
  flex-shrink: 0;
}

.nav-capsule--support {
  width: 60rpx;
  padding: 0;
}

.nav-capsule--menu {
  width: 166rpx;
  gap: 0;
  padding: 0 20rpx;
}

.nav-capsule__icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-capsule__icon--sm {
  width: 28rpx;
  height: 28rpx;
}

.nav-capsule__sep {
  width: 2rpx;
  height: 26rpx;
  margin: 0 16rpx;
}

.detail-scroll {
  flex: 1;
  height: 0;
}

.detail-content {
  padding: 8rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* —— 产品头 —— */
.product-header {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 4rpx 24rpx;
}

.product-header__row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.product-header__flag {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.product-header__title {
  font-size: 40rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.product-header__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.product-header__tag {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 16rpx;
  background: var(--color-bg-base);
  border-radius: 12rpx;
}

.product-header__tag-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.product-header__tag-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-primary);
  line-height: 36rpx;
}

/* —— 价值卡片 —— */
.why-card {
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(159.83deg, #fff3ec 21.15%, #fff 66.95%);
  border-radius: var(--radius-3xl);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  overflow: hidden;
}

.why-card__hero {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.why-card__brand {
  width: 174rpx;
  height: 48rpx;
}

.why-card__tagline {
  font-size: 36rpx;
  font-weight: 500;
  line-height: 48rpx;
  color: var(--color-text-primary);
}

.why-card__tagline-em {
  color: var(--color-primary);
}

.why-card__body {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  margin-top: 24rpx;
}

.why-features {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.why-feature {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 0;
}

.why-feature__icon-wrap {
  flex-shrink: 0;
  padding: 15rpx;
  background: #fff;
  border-radius: 25rpx;
}

.why-feature__icon {
  width: 70rpx;
  height: 70rpx;
  display: block;
}

.why-feature__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.why-feature__title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  line-height: 44rpx;
}

.why-feature__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.why-promise {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.why-promise__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

/* —— 套餐配置卡 —— */
.config-card {
  border-radius: 48rpx;
  border: 4rpx solid var(--color-primary);
  overflow: hidden;
}

.config-card__wrap {
  background: linear-gradient(180deg, var(--rose-50) 6.5%, var(--color-bg-base) 100%);
  box-shadow: 0 30rpx 40rpx #ffece1;
}

.config-card__inner {
  padding: 32rpx 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.config-card__promo {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 12rpx 32rpx 24rpx;
  background: linear-gradient(90deg, #e6485c 0%, #f9733d 95.7%);
}

.config-card__promo-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.config-card__promo-daily {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  color: #fff;
}

.config-card__promo-daily-label,
.config-card__promo-daily-unit {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 40rpx;
}

.config-card__promo-daily-currency {
  font-size: 28rpx;
  font-weight: 500;
}

.config-card__promo-daily-amount {
  font-size: 52rpx;
  font-weight: 600;
  line-height: 64rpx;
  letter-spacing: -1.04rpx;
}

.config-card__promo-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.config-card__promo-tag {
  padding: 4rpx 8rpx;
  background: var(--color-bg-base);
  border-radius: 8rpx;
}

.config-card__promo-tag text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-primary);
  line-height: 32rpx;
  white-space: nowrap;
}

.config-card__promo-countdown {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
}

.config-card__promo-countdown-label {
  font-size: 24rpx;
  color: #fff;
  line-height: 36rpx;
}

.config-card__promo-timer {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.config-card__promo-timer-box {
  min-width: 42rpx;
  padding: 4rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 8rpx;
  font-family: var(--font-family-mono);
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
  text-align: center;
  line-height: 40rpx;
}

.config-card__promo-timer-sep {
  font-family: var(--font-family-mono);
  font-size: 28rpx;
  color: #fff;
  line-height: 40rpx;
}

/* —— eSIM 兼容卡 —— */
.compat-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx 24rpx 40rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(139deg, var(--blue-50) 11.21%, var(--green-50) 89.26%);
}

.compat-card__icon {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.compat-card__content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.panel--usage {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.compat-card__title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.compat-card__subtitle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 32rpx;
}

.compat-card__arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.config-section__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.config-section--days {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.config-section--days .config-section__head {
  margin-bottom: 0;
}

.config-section__label-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.config-section__label-wrap--solo,
.config-section__label-wrap--qty {
  margin-bottom: 24rpx;
}

.config-section__qty-labels {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.config-section__qty-divider {
  width: 2rpx;
  height: 26rpx;
  background: var(--color-border-base);
  flex-shrink: 0;
}

.config-section__label.config-section__label--sub {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.config-section__icon {
  display: block;
  width: 40rpx;
  height: 40rpx;
  max-width: 40rpx;
  max-height: 40rpx;
  flex-shrink: 0;
}

.config-section__label {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.47;
}

.config-section__badge {
  padding: 8rpx 12rpx;
  background: var(--green-100);
  border-radius: 8rpx;
}

.config-section__badge text {
  font-size: 24rpx;
  color: var(--green-700);
  line-height: 1.33;
}

.day-grid {
  display: flex;
  gap: 16rpx;
}

.day-chip {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  border-radius: 20rpx;
}

.day-chip__label {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  line-height: 48rpx;
  white-space: nowrap;
}

.day-chip__price {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-primary);
  line-height: 32rpx;
  white-space: nowrap;
}

.day-chip__badge {
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  padding: 4rpx 8rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, rgba(230, 72, 92, 0.25) 0%, rgba(255, 239, 239, 0) 100%);
  white-space: nowrap;
}

.day-chip--active {
  background: var(--rose-50);
  border-color: var(--color-primary);
}

.day-chip--active .day-chip__label {
  color: var(--color-primary);
}

.day-custom {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  box-sizing: border-box;
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  border-radius: 20rpx;
}

.day-custom__icon {
  width: 40rpx;
  height: 40rpx;
}

.day-custom__text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.day-custom--active {
  background: var(--rose-50);
  border-color: var(--color-primary);
}

.day-custom--active .day-custom__text {
  color: var(--color-primary);
}

.date-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.date-sheet {
  width: 100%;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-base);
  border-radius: 32rpx 32rpx 0 0;
  box-sizing: border-box;
}

.date-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.date-sheet__header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.date-sheet__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.date-sheet__divider {
  width: 1rpx;
  height: 28rpx;
  background: var(--color-border-subtle);
  flex-shrink: 0;
}

.date-sheet__header-days {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.date-sheet__close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
  color: var(--color-text-tertiary);
}

.cal-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.cal-weekdays__item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.cal-weekdays__item--weekend {
  color: var(--color-primary);
}

.date-sheet__calendar {
  flex: 1;
  min-height: 0;
  max-height: 52vh;
}

.cal-month {
  margin-bottom: 32rpx;
}

.cal-month__title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 48rpx;
  margin-bottom: 16rpx;
}

.cal-month__grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cal-week {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.cal-day {
  min-height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  box-sizing: border-box;
}

.cal-day--empty {
  pointer-events: none;
}

.cal-day--disabled .cal-day__num {
  color: var(--color-border-base);
}

.cal-day__num {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.cal-day__tag {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 24rpx;
  color: var(--color-primary);
}

.cal-day--in-range {
  background: var(--green-50);
}

.cal-day--start,
.cal-day--end,
.cal-day--single {
  background: var(--color-secondary);
  border-radius: 20rpx;
}

.cal-day--start:not(.cal-day--end) {
  border-radius: 20rpx 0 0 20rpx;
}

.cal-day--end:not(.cal-day--start) {
  border-radius: 0 20rpx 20rpx 0;
}

.cal-day--start .cal-day__num,
.cal-day--end .cal-day__num,
.cal-day--single .cal-day__num {
  color: #272729;
}

.cal-day--start .cal-day__tag,
.cal-day--end .cal-day__tag,
.cal-day--single .cal-day__tag {
  color: #272729;
  opacity: 0.8;
}

.date-sheet__footer {
  flex-shrink: 0;
  padding-top: 24rpx;
}

.date-sheet__confirm {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.date-sheet__confirm-sep {
  margin: 0 12rpx;
  font-weight: 300;
  font-size: 28rpx;
  color: rgba(39, 39, 41, 0.28);
}

.date-sheet__confirm::after {
  border: none;
}

.qty-stepper {
  display: flex;
  align-items: stretch;
  height: 88rpx;
  border: 2rpx solid var(--color-border-base);
  border-radius: 20rpx;
  overflow: hidden;
}

.qty-stepper__btn {
  width: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-base);
  border-right: 2rpx solid var(--color-border-base);
}

.qty-stepper__btn--plus {
  border-right: none;
  border-left: 2rpx solid var(--color-border-base);
}

.qty-stepper__btn--disabled {
  opacity: 0.35;
}

.qty-stepper__icon {
  width: 48rpx;
  height: 48rpx;
}

.qty-stepper__value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-base);
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.price-summary__divider {
  height: 1rpx;
  background: var(--color-divider);
  margin-bottom: 24rpx;
}

.price-summary__row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.price-summary__total {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price-summary__value {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.price-summary__total-label {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.price-summary__currency {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.price-summary__amount {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-primary);
  line-height: 1;
}

.price-summary__side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.price-summary__daily-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price-summary__daily-label,
.price-summary__daily-unit {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.price-summary__daily-currency {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.price-summary__daily-amount {
  font-size: 60rpx;
  font-weight: 600;
  color: var(--color-primary);
  line-height: 1;
}

.price-summary__promo-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 8rpx;
}

.price-summary__original {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-decoration: line-through;
  opacity: 0.7;
}

.price-summary__save {
  padding: 4rpx 8rpx;
  background: var(--rose-100);
  border-radius: 8rpx;
}

.price-summary__save text {
  font-size: 24rpx;
  color: var(--color-primary);
}

/* —— 通用面板 —— */
.panel {
  padding: 32rpx;
  background: var(--color-bg-base);
  border-radius: 48rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
}

.panel--last {
  margin-bottom: 8rpx;
}

.panel__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel__title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.panel__title--inline {
  margin-bottom: 0;
}

.panel__link {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.panel__link--blue {
  color: #0d8cc2;
}

.panel__subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 32rpx;
}

.panel__intro {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}

.panel--apps {
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.panel__deco {
  position: absolute;
  pointer-events: none;
}

.panel__deco--apps {
  width: 222rpx;
  height: 184rpx;
  top: 0;
  right: 0;
  z-index: 0;
}

.panel--apps .panel__intro {
  max-width: 430rpx;
  position: relative;
  z-index: 1;
}

.panel--apps .panel__subtitle {
  line-height: 36rpx;
  color: var(--color-text-secondary);
}

.panel--apps .panel__divider {
  margin: 0;
  position: relative;
  z-index: 1;
}

.panel__apps-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.panel__link-icon {
  width: 32rpx;
  height: 32rpx;
}

.panel__divider {
  height: 1rpx;
  background: var(--color-divider);
  margin: 24rpx 0;
}

.reviews-card {
  padding: 32rpx;
  background: var(--color-bg-base);
  border-radius: var(--radius-3xl);
