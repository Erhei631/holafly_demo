<view class="detail-page" style="padding-top: {{statusBarHeight}}px;">
  <view class="detail-nav">
    <view class="detail-nav__back" bindtap="onBack" aria-label="返回">
      <image class="detail-nav__back-icon" src="/images/detail/nav-back.svg" mode="aspectFit" />
    </view>
    <text class="detail-nav__title">订单详情</text>
    <view class="detail-nav__right">
      <view class="nav-capsule nav-capsule--menu">
        <image class="nav-capsule__icon nav-capsule__icon--sm" src="/images/detail/nav-share.svg" mode="aspectFit" />
        <image class="nav-capsule__sep" src="/images/detail/nav-divider.svg" mode="aspectFit" />
        <image class="nav-capsule__icon nav-capsule__icon--sm" src="/images/detail/nav-close.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <scroll-view
    class="detail-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    style="padding-bottom: calc(40rpx + {{safeBottom}}px);"
  >
    <view class="detail-tip">
      <image class="detail-tip__icon" src="/images/orders/icon-network-tip.svg" mode="aspectFit" />
      <view class="detail-tip__text-wrap">
        <text class="detail-tip__text">请在有网络的环境下完成安装激活。(</text>
        <text class="detail-tip__highlight">中国大陆设备</text>
        <text class="detail-tip__text">请到达目的地，连接网络后再进行安装激活)。</text>
      </view>
    </view>

    <view class="detail-stack">
      <view class="detail-order-card">
        <view class="detail-order-card__head">
          <text class="detail-order-card__date">{{orderDate}}</text>
        </view>
        <view class="detail-order-card__body">
          <view class="detail-order-card__left">
            <image class="detail-order-card__flag" src="{{order.flag}}" mode="aspectFill" />
            <text class="detail-order-card__name">{{planLabel}}</text>
          </view>
          <view class="detail-order-card__price-wrap">
            <text class="detail-order-card__price">{{priceLabel}}</text>
            <text class="detail-order-card__qty">共 {{order.quantity}} 张</text>
          </view>
        </view>

        <view class="detail-qr-panel" wx:if="{{showQr}}">
          <view class="detail-qr-panel__content">
            <view class="detail-qr-panel__frame">
              <image
                class="detail-qr-panel__image {{esimQrUsed ? 'detail-qr-panel__image--used' : ''}}"
                src="/images/orders/esim-qr.png"
                mode="aspectFill"
                show-menu-by-longpress
              />
            </view>
            <text class="detail-qr-panel__hint">一张 eSIM 仅限一台设备安装</text>
          </view>
          <view class="detail-qr-panel__pager" wx:if="{{esimTotal > 1}}">
            <button
              class="detail-qr-panel__pager-btn detail-qr-panel__pager-btn--muted"
              disabled="{{esimIndex <= 1}}"
              bindtap="onPrevEsim"
              aria-label="上一张"
            >
              <image class="detail-qr-panel__pager-icon" src="/images/orders/icon-qr-prev.svg" mode="aspectFit" />
            </button>
            <view class="detail-qr-panel__pager-count">
              <text class="detail-qr-panel__pager-current">{{esimIndex}}</text>
              <text class="detail-qr-panel__pager-total">/{{esimTotal}}</text>
            </view>
            <button
              class="detail-qr-panel__pager-btn"
              disabled="{{esimIndex >= esimTotal}}"
              bindtap="onNextEsim"
              aria-label="下一张"
            >
              <image class="detail-qr-panel__pager-icon" src="/images/orders/icon-qr-next.svg" mode="aspectFit" />
            </button>
          </view>
          <view class="detail-qr-panel__divider" />
          <view class="detail-qr-panel__actions">
            <button class="detail-qr-panel__btn detail-qr-panel__btn--ghost" bindtap="onSaveQr">保存当前二维码</button>
            <button class="detail-qr-panel__btn detail-qr-panel__btn--primary" bindtap="onInstallGuide">查看安装教程</button>
          </view>
        </view>
      </view>

      <view class="detail-share-banner">
        <view class="detail-share-banner__left">
          <image class="detail-share-banner__coin" src="/images/orders/holapoint.svg" mode="aspectFit" />
          <text class="detail-share-banner__text">分享好友，赚取更多 HolaCoins，好友享专属折扣。</text>
        </view>
        <button class="detail-share-banner__btn" bindtap="onShare">分享</button>
      </view>

      <view class="detail-info-panel">
        <text class="detail-info-panel__title">订单信息</text>
        <view class="detail-info-list">
          <view class="detail-info-row">
            <text class="detail-info-row__label">实付款</text>
            <view class="detail-info-row__right">
              <text class="detail-info-row__sub">合计</text>
              <text class="detail-info-row__value detail-info-row__value--strong">{{priceLabel}}</text>
            </view>
          </view>
          <view class="detail-info-row">
            <text class="detail-info-row__label">下单时间</text>
            <text class="detail-info-row__value">{{order.createdAt}}</text>
          </view>
          <view class="detail-info-row">
            <text class="detail-info-row__label">支付方式</text>
            <text class="detail-info-row__value">微信支付</text>
          </view>
          <view class="detail-info-row">
            <text class="detail-info-row__label">支付时间</text>
            <text class="detail-info-row__value">{{paidAt}}</text>
          </view>
          <view class="detail-info-row">
            <text class="detail-info-row__label">发票信息</text>
            <view class="detail-info-row__invoice" bindtap="onInvoice">申请开票</view>
          </view>
        </view>
      </view>

      <view class="detail-support-btn" bindtap="onSupportTap" aria-label="联系客服">
        <image class="detail-support-btn__icon" src="/images/orders/icon-support-contact.svg" mode="aspectFit" />
        <text class="detail-support-btn__text">联系客服</text>
      </view>

      <view class="detail-refund" bindtap="onRefund">
        <text class="detail-refund__prefix">未激活？</text>
        <text class="detail-refund__link">申请退款</text>
      </view>
    </view>
  </scroll-view>
</view>
