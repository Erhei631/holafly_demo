.page--tab {
  background: var(--color-bg-subtle);
}

.orders-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  padding: var(--space-4);
}

.orders-page__title {
  display: block;
  font-size: var(--font-size-h3);
  font-weight: 600;
  color: var(--color-text-primary);
}

.orders-tabs {
  display: flex;
  gap: var(--space-2);
  margin-top: var(--space-4);
}

.orders-tabs__item {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.orders-tabs__item--active {
  background: var(--rose-50);
  border-color: var(--rose-200);
  color: var(--color-text-brand);
  font-weight: 600;
}

.orders-scroll {
  flex: 1;
  height: 0;
  margin-top: var(--space-4);
}

.orders-empty {
  padding: var(--space-8) var(--space-4);
  text-align: center;
}

.orders-empty__icon {
  display: block;
  font-size: 80rpx;
  line-height: 1;
}

.orders-empty__title {
  display: block;
  margin-top: var(--space-4);
  font-size: var(--font-size-subtitle-2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.orders-empty__hint {
  display: block;
  margin-top: var(--space-2);
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.orders-empty__cta {
  width: 100% !important;
  margin-top: var(--space-5);
}

.order-card {
  margin-bottom: var(--space-3);
  padding: var(--space-4);
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-soft-md);
}

.order-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
}

.order-card__dest {
  display: block;
  font-size: var(--font-size-subtitle-2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.order-card__meta {
  display: block;
  margin-top: var(--space-1);
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.order-card__badge {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-note);
  font-weight: 600;
}

.order-card__badge--warning {
  background: var(--yellow-50);
  color: var(--yellow-700);
}

.order-card__badge--success {
  background: var(--green-50);
  color: var(--green-700);
}

.order-card__badge--muted {
  background: var(--neutral-100);
  color: var(--color-text-tertiary);
}

.order-card__esim {
  margin-top: var(--space-4);
  padding: var(--space-3);
  border-radius: var(--radius-lg);
  background: var(--blue-50);
}

.order-card__esim-label {
  display: block;
  font-size: var(--font-size-note);
  font-weight: 600;
  color: var(--color-text-secondary);
}

.order-card__esim-plan {
  display: block;
  margin-top: var(--space-1);
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
}

.order-card__esim-iccid {
  display: block;
  margin-top: var(--space-1);
  font-size: var(--font-size-note);
  color: var(--color-text-secondary);
  font-family: monospace;
}

.order-card__foot {
  margin-top: var(--space-3);
  padding-top: var(--space-3);
  border-top: 1rpx solid var(--color-divider);
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.order-card__price {
  font-size: var(--font-size-subtitle-2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.order-card__no {
  font-size: var(--font-size-note);
  color: var(--color-text-quaternary);
}

.order-card__actions {
  margin-top: var(--space-3);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.order-card__btn {
  width: 100% !important;
  margin: 0;
}
