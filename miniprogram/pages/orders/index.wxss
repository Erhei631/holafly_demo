.page--tab {
  background: var(--color-bg-subtle);
}

.orders-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  padding: var(--space-4);
}

.orders-page__title {
  display: block;
  font-size: var(--font-size-h3);
  font-weight: 600;
  color: var(--color-text-primary);
}

.orders-tabs {
  display: flex;
  gap: var(--space-2);
  margin-top: var(--space-4);
}

.orders-tabs__item {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

.orders-tabs__item--active {
  background: var(--rose-50);
  border-color: var(--rose-200);
  color: var(--color-text-brand);
  font-weight: 600;
}

.orders-scroll {
  flex: 1;
  height: 0;
  margin-top: var(--space-4);
}

.orders-empty {
  padding: var(--space-8) var(--space-4);
  text-align: center;
}

.orders-empty__icon {
  display: block;
  font-size: 80rpx;
  line-height: 1;
}

.orders-empty__title {
  display: block;
  margin-top: var(--space-4);
  font-size: var(--font-size-subtitle-2);
  font-weight: 600;
  color: var(--color-text-primary);
}

.orders-empty__hint {
  display: block;
  margin-top: var(--space-2);
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.orders-empty__cta {
  width: 100% !important;
  margin-top: var(--space-5);
}

.order-card {
  margin-bottom: var(--space-3);
  background: var(--color-bg-base);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-soft-md);
  overflow: hidden;
}

.order-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.order-card__time {
  font-size: 30rpx;
  color: var(--color-text-muted);
  line-height: 44rpx;
}

.order-card__arrow {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
}

.order-card__body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  padding: 32rpx;
}

.order-card__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.order-card__flag {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.order-card__name {
  font-size: 32rpx;
  font-weight: 500;
  line-height: 44rpx;
}

.order-card__price-wrap {
  text-align: right;
  flex-shrink: 0;
}

.order-card__qty {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 32rpx;
}

.order-card__esim {
  margin: 0 32rpx 32rpx;
  padding: var(--space-3);
  border-radius: var(--radius-lg);
  background: var(--blue-50);
}

.order-card__esim-label {
  display: block;
  font-size: var(--font-size-note);
  font-weight: 600;
  color: var(--color-text-secondary);
}

.order-card__esim-plan {
  display: block;
  margin-top: var(--space-1);
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
}

.order-card__esim-iccid {
  display: block;
  margin-top: var(--space-1);
  font-size: var(--font-size-note);
  color: var(--color-text-secondary);
  font-family: monospace;
}

.order-card__price {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 48rpx;
  color: var(--color-text-primary);
}

.order-card__actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-3);
  padding: 16rpx 24rpx 24rpx;
}

.order-card__btn {
  width: auto !important;
  margin: 0;
  padding: 16rpx 48rpx !important;
}
