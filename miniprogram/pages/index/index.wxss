.page {
  position: relative;
  box-sizing: border-box;
  background: linear-gradient(
    180deg,
    var(--rose-50) 6.5%,
    var(--color-bg-base) 100%
  );
}

.home-scroll {
  position: relative;
  z-index: 1;
  background: transparent;
}

.home-header {
  position: relative;
  z-index: 2;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 14rpx 0 40rpx;
  box-sizing: content-box;
}

.nav-capsule {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #dedede;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.nav-capsule--menu {
  width: 166rpx;
  padding: 0 20rpx;
}

.nav-capsule__icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-capsule__icon--sm {
  width: 28rpx;
  height: 28rpx;
}

.nav-capsule__sep {
  width: 2rpx;
  height: 26rpx;
  margin: 0 16rpx;
}

.hero__map {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 280rpx;
  z-index: 0;
  pointer-events: none;
  display: block;
}

.hero {
  position: relative;
  z-index: 1;
  padding: 0 40rpx 48rpx;
}

.brand {
  display: flex;
  align-items: center;
}

.brand__logo {
  width: 220rpx;
  height: 68rpx;
  display: block;
}

.home-main {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  margin-top: 28rpx;
}

/* —— 优惠横幅 —— */
.promo-card {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.promo-card__swiper {
  width: 100%;
  height: 156rpx;
}

.promo-card__banner {
  width: 100%;
  height: 156rpx;
  display: block;
  border-radius: var(--radius-2xl);
}

.promo-card__inner {
  position: relative;
  width: 100%;
  min-height: 156rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 32rpx;
  border-radius: var(--radius-2xl);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  background: linear-gradient(176.84deg, #f2fdeb 0%, #e0f4fd 100%);
  overflow: hidden;
  box-sizing: border-box;
}

.promo-card__left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 2;
  min-width: 0;
}

.promo-card__icon {
  width: 124rpx;
  height: 124rpx;
  flex-shrink: 0;
}

.promo-card__text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.promo-card__title {
  font-size: 30rpx;
  font-weight: 500;
  line-height: 44rpx;
  color: var(--color-text-primary);
}

.promo-card__desc {
  font-size: 24rpx;
  line-height: 36rpx;
  color: var(--color-text-tertiary);
}

.promo-card__copy {
  flex-shrink: 0;
  margin: 0;
  padding: 12rpx 40rpx;
  border-radius: 48rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #fff;
  background: linear-gradient(116.29deg, #e6485c 20.26%, #e12b57 74.93%);
  z-index: 2;
}

.promo-card__copy::after {
  border: none;
}

.promo-card__deco {
  position: absolute;
  right: -112rpx;
  top: -54rpx;
  width: 266rpx;
  height: 244rpx;
  pointer-events: none;
  z-index: 1;
}

.promo-card__dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.promo-card__dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 20rpx;
  background: rgba(39, 39, 41, 0.1);
}

.promo-card__dot--active {
  width: 28rpx;
  background: rgba(39, 39, 41, 0.3);
}

/* —— 实时动态 —— */
.activity-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-xl);
  background: linear-gradient(97.68deg, #c8ebfe 0.93%, #fcecfc 64.67%, var(--yellow-50) 95.71%);
  overflow: hidden;
}

.activity-bar__chip {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 48rpx;
  padding: 8rpx 16rpx;
  background: var(--rose-50);
  border-radius: 12rpx;
}

.activity-bar__chip-text {
  font-size: 24rpx;
  color: var(--color-primary);
  line-height: 32rpx;
}

.activity-bar__sep {
  width: 1rpx;
  height: 32rpx;
  background: var(--color-divider);
  flex-shrink: 0;
}

.activity-bar__swiper {
  flex: 1;
  min-width: 0;
  height: 40rpx;
}

.activity-bar__item {
  display: flex;
  align-items: center;
  height: 40rpx;
  overflow: hidden;
}

.activity-bar__text {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  line-height: 1.43;
  white-space: nowrap;
}

.activity-bar__highlight {
  font-size: var(--font-size-body);
  color: var(--color-primary);
  line-height: 1.43;
  white-space: nowrap;
}

/* —— 搜索区 —— */
.search-block {
  width: 100%;
}

.search-block__shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx;
  background: var(--blue-100);
  border-radius: var(--radius-3xl);
  box-sizing: border-box;
}

.search-card {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  padding: 32rpx 40rpx;
  background: var(--color-bg-base);
  border-radius: var(--radius-2xl);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

@keyframes search-card-dest-border-flow {
  0% { background-position: 0% 50%; }
  100% { background-position: 300% 50%; }
}

.search-card__dest-box {
  position: relative;
  width: 100%;
  padding: 32rpx 20rpx;
  border-radius: var(--radius-sm);
  background: rgba(255, 239, 239, 0.2);
  box-shadow: 0 4rpx 40rpx rgba(230, 72, 92, 0.12);
  box-sizing: border-box;
}

.search-card__dest-box::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 4rpx;
  background: linear-gradient(
    90deg,
    #bfebff,
    #f9eef8,
    #ffccb0,
    #fcecfc,
    #bfebff,
    #f9eef8
  );
  background-size: 300% 100%;
  animation: search-card-dest-border-flow 4s linear infinite;
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  mask-composite: exclude;
  pointer-events: none;
}

.search-card__dest {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  width: 100%;
}

.search-card__dest-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-width: 0;
}

.search-card__icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.search-card__label {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  line-height: 44rpx;
  white-space: nowrap;
}

.search-card__vsep {
  width: 1rpx;
  height: 32rpx;
  background: var(--color-divider);
  flex-shrink: 0;
}

.search-card__value {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--color-text-tertiary);
  line-height: 44rpx;
  white-space: nowrap;
}

.search-card__value--selected {
  color: var(--color-text-primary);
}

.search-card__arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

/* —— 热门推荐 —— */
.popular-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.popular-section__title {
  font-size: 30rpx;
  font-weight: 500;
  line-height: 44rpx;
  color: var(--color-text-secondary);
}

.popular-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.popular-chip {
  width: calc((100% - 16rpx) / 2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  border-radius: 20rpx;
  box-sizing: border-box;
}

.popular-chip__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.popular-chip__flag {
  width: 60rpx;
  height: 60rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.popular-chip__name {
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.47;
}

.popular-chip__arrow {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.popular-more {
  width: 100%;
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text-tertiary);
  text-align: center;
}

/* —— 教育卡片 —— */
.edu-cards {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 24rpx;
  width: 100%;
}

.edu-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 36rpx 32rpx 40rpx;
  border-radius: var(--radius-2xl);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
}

.edu-card--esim {
  background: linear-gradient(172deg, #f2fdeb 0%, #e0f4fd 100%);
}

.edu-card--compat {
  background: linear-gradient(116deg, var(--yellow-50) 11%, var(--rose-50) 89%);
}

.edu-card__icon {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.edu-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.edu-card__tag {
  font-size: var(--font-size-note);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.edu-card__text-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.edu-card__title {
  font-size: var(--font-size-subtitle-2);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.edu-card__desc {
  font-size: var(--font-size-note);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* —— Trustpilot 评价 —— */
.reviews-card {
  padding: 32rpx;
  background: var(--color-bg-base);
  border-radius: var(--radius-3xl);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.reviews-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.reviews-card__brand {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.reviews-card__logo {
  width: 182rpx;
  height: 48rpx;
  display: block;
}

.reviews-card__count {
  font-size: var(--font-size-body);
  color: var(--color-text-tertiary);
  line-height: 1.43;
}

.reviews-card__rating {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.reviews-card__score {
  font-family: var(--font-family-mono);
  font-size: 36rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: var(--color-primary);
  line-height: 1;
}

.reviews-card__max {
  font-family: var(--font-family-mono);
  font-size: var(--font-size-subtitle-2);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  color: var(--color-text-primary);
  line-height: 1;
  padding-bottom: 2rpx;
}

.reviews-card__arrow {
  width: 32rpx;
  height: 32rpx;
}

.reviews-card__divider {
  height: 1rpx;
  margin: 32rpx 0;
  background: var(--color-divider);
}

.reviews-scroll {
  width: 100%;
}

.reviews-list {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  padding-right: 8rpx;
}

.review-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 296rpx;
  flex-shrink: 0;
  padding: 20rpx 32rpx;
  background: var(--neutral-100);
  border-radius: var(--radius-2xl);
  box-shadow: 0 4rpx 4rpx rgba(0, 0, 0, 0.05);
}

.review-item__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.review-item__name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.47;
}

.review-item__badge {
  padding: 4rpx 8rpx;
  background: var(--rose-100);
  border-radius: 8rpx;
}

.review-item__badge-text {
  font-family: var(--font-family-mono);
  font-size: var(--font-size-note);
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: var(--color-primary);
  line-height: 1.33;
}

.review-item__text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  line-height: 1.47;
}

.review-item__meta {
  font-size: var(--font-size-note);
  color: var(--color-text-tertiary);
  line-height: 1.33;
}

/* —— Holafly 价值板块 —— */
.why-card {
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(144.05deg, #fff3ec 21.15%, #fff 66.95%);
  border-radius: var(--radius-3xl);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  overflow: hidden;
}

.why-card__hero {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.why-card__brand {
  width: 174rpx;
  height: 48rpx;
}

.why-card__tagline {
  font-size: 36rpx;
  font-weight: 500;
  line-height: 48rpx;
  color: var(--color-text-primary);
}

.why-card__tagline-em {
  color: var(--color-primary);
}

.why-card__body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 24rpx;
}

.why-features {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.why-feature {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 0;
}

.why-feature__icon-wrap {
  flex-shrink: 0;
  padding: 15rpx;
  background: #fff;
  border-radius: 25rpx;
}

.why-feature__icon {
  width: 70rpx;
  height: 70rpx;
  display: block;
}

.why-feature__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.why-feature__title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  line-height: 44rpx;
}

.why-feature__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 36rpx;
}

.esim-card {
  padding: 32rpx;
  background: #fff;
  border-radius: var(--radius-3xl);
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.esim-card__section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.esim-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.esim-card__title {
  font-size: 32rpx;
  font-weight: 500;
  line-height: 48rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.esim-card__link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text-secondary);
}

.esim-card__arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.esim-card__desc {
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text-secondary);
}

.esim-card__emph {
  color: var(--color-primary);
}

.esim-card__divider {
  height: 1rpx;
  background: var(--color-border-subtle);
}

.usage-steps {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.usage-steps__connector {
  flex: 1;
  align-self: flex-start;
  min-width: 16rpx;
  height: 0;
  margin-top: 44rpx;
  border-top: 2rpx dashed var(--neutral-300);
}

.usage-step {
  width: 148rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.usage-step__icon-wrap {
  padding: 20rpx;
  background: var(--rose-50);
  border-radius: var(--radius-2xl);
}

.usage-step__icon {
  width: 48rpx;
  height: 48rpx;
  display: block;
}

.usage-step__label {
  width: 148rpx;
  min-height: 64rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 36rpx;
  text-align: center;
}

.esim-compat-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 36rpx 24rpx 40rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(139deg, var(--blue-50) 11.21%, var(--green-50) 89.26%);
}

.esim-compat-card__left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-width: 0;
}

.esim-compat-card__icon {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.esim-compat-card__text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.esim-compat-card__name {
  font-size: 30rpx;
  font-weight: 500;
  line-height: 44rpx;
  color: var(--color-text-primary);
}

.esim-compat-card__desc {
  font-size: 24rpx;
  line-height: 36rpx;
  color: var(--color-text-secondary);
}

.esim-compat-card__arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.compare-wrap {
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.05);
  background: #fff;
}

.compare-table {
  position: relative;
  width: 100%;
}

.compare-highlight {
  position: absolute;
  left: 144rpx;
  top: 0;
  bottom: 0;
  width: calc((100% - 144rpx) / 3);
  border-radius: 20rpx;
  background: linear-gradient(124.135deg, #bfebff 21.92%, #f9eef8 53.4%, #ffccb0 131.92%);
  pointer-events: none;
  z-index: 1;
}

.compare-row {
  display: flex;
  align-items: stretch;
}

.compare-row--head {
  height: 156rpx;
}

.compare-row:not(.compare-row--head) {
  height: 88rpx;
}

.compare-cell {
  position: relative;
  z-index: 0;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-top: 1rpx solid #e4e6ea;
  background: #fff;
}

.compare-cell--label {
  position: sticky;
  left: 0;
  z-index: 4;
  width: 144rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #202c40;
  line-height: 40rpx;
  text-align: center;
}

.compare-cell--head {
  background: #f8f8fb;
  color: #94a2ba;
  font-size: 22rpx;
}

.compare-row--alt .compare-cell--label {
  background: #f8f8fb;
}

.compare-col {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
}

.compare-row--head .compare-col:not(.compare-col--holafly) {
  background: #f8f8fb;
}

.compare-col--holafly {
  position: relative;
  z-index: 2;
  background: transparent !important;
  border-top-color: transparent !important;
}

.compare-row:last-child .compare-col--holafly {
  border-bottom-color: transparent !important;
}

.compare-row--alt .compare-col:not(.compare-col--holafly) {
  background: #f8f8fb;
}

.compare-row:last-child .compare-cell {
  border-bottom: 1rpx solid #e4e6ea;
}

.compare-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.compare-head__logo {
  width: 134rpx;
  height: 42rpx;
}

.compare-head__title {
  font-size: 30rpx;
  font-weight: 500;
  line-height: 44rpx;
  color: #202c40;
  text-align: center;
}

.compare-head__sub {
  font-size: 22rpx;
  font-weight: 500;
  line-height: 30rpx;
  color: #94a2ba;
  text-align: center;
}

.compare-val {
  font-size: 24rpx;
  line-height: 32rpx;
  text-align: center;
  white-space: nowrap;
}

.compare-val--primary {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 40rpx;
  color: #e6485c;
}

.compare-col--holafly .compare-val--primary {
  font-size: 26rpx;
  line-height: 38rpx;
}

.compare-val--muted {
  font-weight: 400;
  color: #74839d;
}

/* —— 手机兼容测试抽屉 —— */
.compat-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1010;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.compat-sheet-mask--show {
  opacity: 1;
  pointer-events: auto;
}

.compat-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1011;
  width: 100%;
  height: 82vh;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: var(--color-bg-base);
  border-radius: 48rpx 48rpx 0 0;
  padding-top: 24rpx;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
  pointer-events: none;
  will-change: transform;
}

.compat-sheet--show {
  transform: translateY(0);
  pointer-events: auto;
}

.compat-sheet__handle-wrap {
  display: flex;
  justify-content: center;
  padding: 8rpx 0 16rpx;
  flex-shrink: 0;
}

.compat-sheet__handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: var(--color-border-base);
}

.compat-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx;
  min-height: 104rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.compat-sheet__title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.compat-sheet__close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.compat-sheet__close-icon {
  width: 56rpx;
  height: 56rpx;
}

.compat-device-block {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.compat-sheet__section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 16rpx 40rpx 0;
  flex-shrink: 0;
  box-sizing: border-box;
}

.compat-sheet__body {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 32rpx 40rpx 0;
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.compat-sheet__label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 32rpx;
}

.compat-step-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 32rpx;
  padding-left: 36rpx;
  text-indent: -36rpx;
}

.compat-version-row {
  display: flex;
  gap: 16rpx;
}

.compat-version {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--color-bg-base);
  border: 2rpx solid var(--color-border-base);
  border-radius: 32rpx;
  box-sizing: border-box;
}

.compat-version--active.compat-version--cn {
  background: var(--blue-50);
  border-color: #4db5e8;
}

.compat-version--active.compat-version--global {
  background: var(--rose-50);
  border-color: var(--color-primary);
}

.compat-version__icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.compat-version__text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.compat-version__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.compat-version__subtitle {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 32rpx;
}

.compat-segment {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  background: var(--color-border-base);
  border-radius: 24rpx;
}

.compat-segment__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.compat-segment__item--active {
  background: var(--color-bg-base);
  box-shadow: 0 4rpx 16rpx -8rpx rgba(0, 0, 0, 0.2);
}

.compat-model-panel {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.compat-search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: var(--color-bg-muted);
  border-radius: 48rpx;
}

.compat-search__icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.compat-search__input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.compat-search__placeholder {
  color: var(--color-text-secondary);
}

.compat-models {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.compat-model {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 0;
  box-sizing: border-box;
}

.compat-model__divider {
  height: 1rpx;
  background: var(--color-bg-muted);
  width: 100%;
}

.compat-model__divider + .compat-sheet__label {
  margin-top: 32rpx;
}

.compat-model__name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.compat-model__badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  background: var(--green-100);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #179b50;
  line-height: 32rpx;
  flex-shrink: 0;
}

.compat-model__check {
  width: 28rpx;
  height: 28rpx;
}

.compat-dial {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.compat-dial__intro {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
  background: var(--neutral-100);
  border-radius: 20rpx;
}

.compat-dial__intro-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.compat-dial__intro-text {
  font-size: 30rpx;
  color: var(--neutral-500);
  line-height: 44rpx;
}

.compat-dial__code-inline {
  padding: 0 8rpx;
  border-radius: 8rpx;
  background: var(--rose-100);
  color: #e5174a;
  font-weight: 500;
}

.compat-dial__phones {
  width: 100%;
  display: block;
}

.compat-dial__steps {
  overflow: hidden;
  border: 2rpx solid var(--color-border-base);
  border-radius: 28rpx;
  background: #fff;
}

.compat-dial__step {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--color-border-base);
}

.compat-dial__step:last-child {
  border-bottom: none;
}

.compat-dial__step-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.compat-dial__step-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.compat-dial__step-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.compat-dial__step-desc {
  font-size: 24rpx;
  color: var(--neutral-400);
  line-height: 36rpx;
}

.compat-dial__results {
  display: flex;
  gap: 16rpx;
}

.compat-dial__result {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 26rpx 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid;
}

.compat-dial__result--success {
  background: rgba(30, 158, 106, 0.1);
  border-color: var(--green-700);
}

.compat-dial__result--neutral {
  background: #fff;
  border-color: #d7dae0;
}

.compat-dial__result-title {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 40rpx;
  text-align: center;
}

.compat-dial__result-title--success {
  color: var(--green-700);
}

.compat-dial__result-title--neutral {
  color: var(--neutral-500);
}

.compat-dial__result-desc {
  font-size: 24rpx;
  color: var(--neutral-500);
  line-height: 36rpx;
  text-align: center;
}
