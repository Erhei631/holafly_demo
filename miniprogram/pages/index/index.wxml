<view class="page page--tab">
  <image class="hero__map" src="/images/home/map-watermark.png" mode="aspectFill" />
  <scroll-view class="page-scroll home-scroll" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="hero-top">
    <view class="brand">
      <image class="brand__logo" src="/images/home/logo.svg" mode="aspectFit" />
      <text class="brand__title">出境上网助手</text>
    </view>
  </view>

  <view class="hero">
    <view class="home-main">
      <image
        class="promo-banner"
        src="/images/home/promo-banner.png"
        mode="widthFix"
        bindtap="onClaimPromoTap"
      />

      <view class="activity-bar">
        <view class="activity-bar__chip">
          <text class="activity-bar__chip-text">实时</text>
        </view>
        <view class="activity-bar__sep" />
        <swiper
          class="activity-bar__swiper"
          vertical
          autoplay
          circular
          interval="3000"
          duration="400"
        >
          <swiper-item wx:for="{{activityFeed}}" wx:key="id">
            <view class="activity-bar__item">
              <text class="activity-bar__text">{{item.prefix}}</text>
              <text class="activity-bar__highlight">{{item.product}}</text>
            </view>
          </swiper-item>
        </swiper>
      </view>

      <view class="search-block">
        <view class="search-block__shell">
          <view class="search-block__perks">
            <text class="search-block__perk">7 × 24小时客服</text>
            <text class="search-block__perk-sep">|</text>
            <text class="search-block__perk">无限流量</text>
            <text class="search-block__perk-sep">|</text>
            <text class="search-block__perk">200+国家覆盖</text>
          </view>

          <view class="search-card">
            <view class="search-card__dest" bindtap="openDestinationDrawer">
              <image class="search-card__icon" src="/images/home/icon-airplane.svg" mode="aspectFit" />
              <view class="search-card__dest-row">
                <text class="search-card__label">目的地</text>
                <view class="search-card__vsep" />
                <text class="search-card__value">{{destinationDisplay}}</text>
                <image class="search-card__chevron" src="/images/home/icon-chevron-down.svg" mode="aspectFit" />
              </view>
            </view>

            <view class="search-card__divider" />

            <button class="search-card__cta" bindtap="onViewPlansTap">查看套餐</button>

            <view class="popular-section">
              <text class="popular-section__title">热门推荐</text>
              <view class="popular-grid">
                <view
                  wx:for="{{popularRecommendations}}"
                  wx:key="id"
                  class="popular-chip"
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                  bindtap="onPopularRecommendTap"
                >
                  <view class="popular-chip__left">
                    <image class="popular-chip__flag" src="{{item.flag}}" mode="aspectFill" />
                    <text class="popular-chip__name">{{item.name}}</text>
                  </view>
                  <image class="popular-chip__arrow" src="/images/home/icon-chevron-down.svg" mode="aspectFit" />
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="edu-cards">
        <view class="edu-card edu-card--esim" bindtap="onEsimCardTap">
          <image class="edu-card__icon" src="/images/home/card-esim.svg" mode="aspectFit" />
          <view class="edu-card__body">
            <text class="edu-card__tag">eSIM</text>
            <view class="edu-card__text-group">
              <text class="edu-card__title">什么是eSIM</text>
              <text class="edu-card__desc">无需换卡</text>
            </view>
          </view>
        </view>
        <view class="edu-card edu-card--compat" bindtap="onCompatCardTap">
          <image class="edu-card__icon" src="/images/home/card-device.svg" mode="aspectFit" />
          <view class="edu-card__body">
            <text class="edu-card__tag">设备</text>
            <view class="edu-card__text-group">
              <text class="edu-card__title">兼容测试</text>
              <text class="edu-card__desc">手机能用吗</text>
            </view>
          </view>
        </view>
      </view>

      <view class="reviews-card">
        <view class="reviews-card__header">
          <view class="reviews-card__brand">
            <image class="reviews-card__logo" src="/images/home/trustpilot-logo.svg" mode="aspectFit" />
            <text class="reviews-card__count">来自 95,304 位用户评价</text>
          </view>
          <view class="reviews-card__rating">
            <text class="reviews-card__score">4.7</text>
            <text class="reviews-card__max">/5</text>
            <image class="reviews-card__arrow" src="/images/home/icon-arrow-right.svg" mode="aspectFit" />
          </view>
        </view>
        <view class="reviews-card__divider" />
        <view class="reviews-list">
          <view wx:for="{{reviews}}" wx:key="id" class="review-item">
            <view class="review-item__top">
              <text class="review-item__name">{{item.name}}</text>
              <view class="review-item__badge">
                <text class="review-item__badge-text">{{item.rating}}</text>
              </view>
            </view>
            <text class="review-item__text">{{item.text}}</text>
            <text class="review-item__meta">{{item.meta}}</text>
          </view>
        </view>
      </view>

      <view class="compare-card">
        <text class="compare-card__title">Holafly 核心优势</text>
        <scroll-view class="compare-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="compare-highlight" />
          <view class="compare-table">
            <view class="compare-row compare-row--head">
              <view class="compare-cell compare-cell--label compare-cell--head">权益</view>
              <view
                wx:for="{{compare.columns}}"
                wx:key="id"
                class="compare-cell compare-col {{item.primary ? 'compare-col--holafly' : ''}}"
              >
                <view wx:if="{{item.primary}}" class="compare-head">
                  <image class="compare-head__logo" src="/images/home/logo.svg" mode="aspectFit" />
                  <text class="compare-head__sub">{{item.sub}}</text>
                </view>
                <view wx:else class="compare-head">
                  <text class="compare-head__title">{{item.name}}</text>
                  <text class="compare-head__sub">{{item.sub}}</text>
                </view>
              </view>
            </view>
            <view
              wx:for="{{compare.rows}}"
              wx:key="id"
              class="compare-row {{index % 2 === 1 ? 'compare-row--alt' : ''}}"
            >
              <view class="compare-cell compare-cell--label">{{item.label}}</view>
              <view
                wx:for="{{item.cells}}"
                wx:for-item="cell"
                wx:for-index="colIndex"
                wx:key="colIndex"
                class="compare-cell compare-col {{colIndex === 0 ? 'compare-col--holafly' : ''}}"
              >
                <text class="compare-val compare-val--{{cell.tone}}">{{cell.text}}</text>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>
  </scroll-view>

  <view
    class="drawer-mask {{showDestinationDrawer ? 'drawer-mask--show' : ''}}"
    bindtap="closeDestinationDrawer"
    catchtouchmove="noop"
  />
  <view
    class="drawer {{showDestinationDrawer ? 'drawer--show' : ''}}"
    style="padding-bottom: {{safeBottom}}px;"
    catchtouchmove="noop"
  >
    <view class="drawer__handle-wrap">
      <view class="drawer__handle" />
    </view>
    <view class="drawer__header">
      <text class="drawer__title">选择国家/地区</text>
      <view class="drawer__close" bindtap="closeDestinationDrawer">
        <image class="drawer__close-icon" src="/images/home/drawer-close.png" mode="aspectFit" />
      </view>
    </view>

    <view class="drawer__search-wrap">
      <view class="drawer__search">
        <image class="drawer__search-icon" src="/images/home/drawer-search.svg" mode="aspectFit" />
        <input
          class="drawer__search-input"
          placeholder="搜索国家/地区"
          placeholder-class="drawer__search-placeholder"
          value="{{drawerKeyword}}"
          bindinput="onDrawerSearchInput"
          confirm-type="search"
        />
      </view>
    </view>

    <scroll-view class="drawer__scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:if="{{filteredPopularCountries.length === 0 && filteredMultiRegions.length === 0}}"
        class="drawer__empty"
      >
        未找到相关国家/地区
      </view>

      <view wx:if="{{filteredPopularCountries.length}}" class="drawer__section">
        <text class="drawer__section-title">热门目的地</text>
        <view class="dest-chips">
          <view
            wx:for="{{filteredPopularCountries}}"
            wx:key="id"
            class="dest-chip {{selectedDestinationId === item.id ? 'dest-chip--active' : ''}}"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
            bindtap="onSelectDestinationChip"
          >
            <image class="dest-chip__icon" src="{{item.icon}}" mode="aspectFill" />
            <text class="dest-chip__label">{{item.name}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{filteredPopularCountries.length && filteredMultiRegions.length}}" class="drawer__divider" />

      <view wx:if="{{filteredMultiRegions.length}}" class="drawer__section">
        <text class="drawer__section-title">多国通用</text>
        <view class="dest-chips">
          <view
            wx:for="{{filteredMultiRegions}}"
            wx:key="id"
            class="dest-chip {{selectedDestinationId === item.id ? 'dest-chip--active' : ''}}"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
            bindtap="onSelectDestinationChip"
          >
            <image class="dest-chip__icon" src="{{item.icon}}" mode="aspectFill" />
            <text class="dest-chip__label">{{item.name}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view
    class="compat-sheet-mask {{showCompatSheet ? 'compat-sheet-mask--show' : ''}}"
    bindtap="onCloseCompatSheet"
    catchtouchmove="noop"
  />
  <view
    class="compat-sheet {{showCompatSheet ? 'compat-sheet--show' : ''}}"
    style="padding-bottom: {{safeBottom}}px;"
    catchtap="noop"
    catchtouchmove="noop"
  >
    <view class="compat-sheet__handle-wrap">
      <view class="compat-sheet__handle" />
    </view>
    <view class="compat-sheet__header">
      <text class="compat-sheet__title">检查我的手机是否支持 eSIM</text>
      <view class="compat-sheet__close" bindtap="onCloseCompatSheet" aria-label="关闭">
        <image class="compat-sheet__close-icon" src="/images/compat/close.svg" mode="aspectFit" />
      </view>
    </view>
    <scroll-view class="compat-sheet__scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="compat-sheet__section">
        <text class="compat-sheet__label">您的手机是哪个版本</text>
        <view class="compat-version-row">
          <view
            wx:for="{{compatVersions}}"
            wx:key="id"
            class="compat-version {{compatVersion === item.id ? 'compat-version--active' : ''}}"
            data-version="{{item.id}}"
            bindtap="onCompatVersionTap"
          >
            <image class="compat-version__icon" src="{{item.icon}}" mode="aspectFill" />
            <view class="compat-version__text">
              <text class="compat-version__title">{{item.title}}</text>
              <text class="compat-version__subtitle">{{item.subtitle}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="compat-sheet__body">
        <text class="compat-sheet__label">选择查询方式</text>
        <view class="compat-segment">
          <view
            wx:for="{{compatMethods}}"
            wx:key="id"
            class="compat-segment__item {{compatMethod === item.id ? 'compat-segment__item--active' : ''}}"
            data-method="{{item.id}}"
            bindtap="onCompatMethodTap"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
        <block wx:if="{{compatMethod === 'model'}}">
          <view class="compat-search">
            <image class="compat-search__icon" src="/images/compat/search.svg" mode="aspectFit" />
            <input
              class="compat-search__input"
              placeholder="搜索手机品牌或型号"
              placeholder-class="compat-search__placeholder"
              value="{{compatSearch}}"
              bindinput="onCompatSearchInput"
            />
          </view>
          <view class="compat-models">
            <text class="compat-sheet__label">热门机型</text>
            <view
              wx:for="{{filteredCompatModels}}"
              wx:key="id"
              class="compat-model"
            >
              <text class="compat-model__name">{{item.name}}</text>
              <view wx:if="{{item.supported}}" class="compat-model__badge">
                <image class="compat-model__check" src="/images/compat/check.svg" mode="aspectFit" />
                <text>支持</text>
              </view>
            </view>
          </view>
        </block>
        <view wx:else class="compat-dial">
          <text class="compat-dial__code">*#06#</text>
          <text class="compat-dial__hint">{{compatDialHint}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
