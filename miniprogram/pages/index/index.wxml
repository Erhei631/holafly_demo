<view class="page page--tab">
  <image class="hero__map" src="/images/home/map-watermark.png" mode="aspectFill" />
  <view class="home-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="brand">
      <image class="brand__logo" src="/images/home/logo.svg" mode="aspectFit" />
    </view>
    <view class="nav-capsule nav-capsule--menu">
      <image class="nav-capsule__icon nav-capsule__icon--sm" src="/images/detail/nav-share.svg" mode="aspectFit" />
      <image class="nav-capsule__sep" src="/images/detail/nav-divider.svg" mode="aspectFit" />
      <image class="nav-capsule__icon nav-capsule__icon--sm" src="/images/detail/nav-close.svg" mode="aspectFit" />
    </view>
  </view>
  <scroll-view class="page-scroll home-scroll" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="hero">
    <view class="home-main">
      <view class="promo-card">
        <swiper
          class="promo-card__swiper"
          circular
          autoplay
          interval="4000"
          duration="400"
          current="{{promoIndex}}"
          bindchange="onPromoChange"
        >
          <swiper-item>
            <image class="promo-card__banner" src="/images/home/promo-banner-2.png" mode="aspectFill" />
          </swiper-item>
          <swiper-item>
            <image class="promo-card__banner" src="/images/home/promo-banner-1.png" mode="aspectFill" />
          </swiper-item>
          <swiper-item>
            <image class="promo-card__banner" src="/images/home/promo-banner-3.png" mode="aspectFill" />
          </swiper-item>
        </swiper>
        <view class="promo-card__dots" aria-hidden="true">
          <view class="promo-card__dot {{promoIndex === 0 ? 'promo-card__dot--active' : ''}}" />
          <view class="promo-card__dot {{promoIndex === 1 ? 'promo-card__dot--active' : ''}}" />
          <view class="promo-card__dot {{promoIndex === 2 ? 'promo-card__dot--active' : ''}}" />
        </view>
      </view>

      <view class="activity-bar">
        <view class="activity-bar__chip">
          <text class="activity-bar__chip-text">实时</text>
        </view>
        <view class="activity-bar__sep" />
        <swiper
          class="activity-bar__swiper"
          vertical
          autoplay
          circular
          interval="3000"
          duration="400"
        >
          <swiper-item wx:for="{{activityFeed}}" wx:key="id">
            <view class="activity-bar__item">
              <text class="activity-bar__text">{{item.prefix}}</text>
              <text class="activity-bar__highlight">{{item.product}}</text>
            </view>
          </swiper-item>
        </swiper>
      </view>

      <view class="search-block">
        <view class="search-block__shell">
          <view class="search-card">
            <view class="search-card__dest-box">
              <view class="search-card__dest" bindtap="openDestinationDrawer">
                <view class="search-card__dest-main">
                  <image class="search-card__icon" src="/images/home/icon-airplane.svg" mode="aspectFit" />
                  <text class="search-card__label">目的地</text>
                  <view class="search-card__vsep" />
                  <text class="search-card__value {{destinationSelected ? 'search-card__value--selected' : ''}}">{{destinationDisplay}}</text>
                </view>
                <image class="search-card__arrow" src="/images/home/icon-arrow-right-dest.svg" mode="aspectFit" />
              </view>
            </view>

            <view class="popular-section">
              <text class="popular-section__title">热门推荐</text>
              <view class="popular-grid">
                <view
                  wx:for="{{popularRecommendations}}"
                  wx:key="id"
                  class="popular-chip"
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                  bindtap="onPopularRecommendTap"
                >
                  <view class="popular-chip__left">
                    <image class="popular-chip__flag" src="{{item.flag}}" mode="aspectFill" />
                    <text class="popular-chip__name">{{item.name}}</text>
                  </view>
                  <image class="popular-chip__arrow" src="/images/home/icon-arrow-right-bold.svg" mode="aspectFit" />
                </view>
              </view>
              <view class="popular-more" bindtap="openDestinationDrawer">查看更多目的地</view>
            </view>
          </view>
        </view>
      </view>

      <view class="why-card">
        <view class="why-card__hero">
          <image class="why-card__brand" src="/images/home/why-brand-logo.svg" mode="aspectFit" />
          <view class="why-card__tagline">
            <text>旅途充满未知，连接</text>
            <text class="why-card__tagline-em">始终可靠</text>
          </view>
        </view>

        <view class="why-card__body">
          <view class="why-features">
            <view wx:for="{{whyChoose}}" wx:key="id" class="why-feature">
              <view class="why-feature__icon-wrap">
                <image class="why-feature__icon" src="{{item.icon}}" mode="aspectFill" />
              </view>
              <view class="why-feature__body">
                <text class="why-feature__title">{{item.title}}</text>
                <text class="why-feature__desc">{{item.desc}}</text>
              </view>
            </view>
          </view>

          <view class="compare-wrap">
            <view class="compare-table">
              <view class="compare-highlight" />
              <view class="compare-row compare-row--head">
                <view class="compare-cell compare-cell--label compare-cell--head">权益</view>
                <view
                  wx:for="{{compare.columns}}"
                  wx:key="id"
                  class="compare-cell compare-col {{item.primary ? 'compare-col--holafly' : ''}}"
                >
                  <view wx:if="{{item.primary}}" class="compare-head">
                    <image class="compare-head__logo" src="/images/home/compare-holafly-text.svg" mode="aspectFit" />
                    <text class="compare-head__sub">{{item.sub}}</text>
                  </view>
                  <view wx:else class="compare-head">
                    <text class="compare-head__title">{{item.name}}</text>
                    <text class="compare-head__sub">{{item.sub}}</text>
                  </view>
                </view>
              </view>
              <view
                wx:for="{{compare.rows}}"
                wx:key="id"
                class="compare-row {{item.alt ? 'compare-row--alt' : ''}}"
              >
                <view class="compare-cell compare-cell--label">{{item.label}}</view>
                <view
                  wx:for="{{item.cells}}"
                  wx:for-item="cell"
                  wx:for-index="colIndex"
                  wx:key="colIndex"
                  class="compare-cell compare-col {{colIndex === 0 ? 'compare-col--holafly' : ''}}"
                >
                  <text class="compare-val compare-val--{{cell.tone}}">{{cell.text}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="esim-card">
        <view class="esim-card__section">
          <view class="esim-card__head">
            <text class="esim-card__title">什么是eSIM？</text>
            <view class="esim-card__link" bindtap="onEsimCardTap">
              <text>查看完整说明</text>
              <image class="esim-card__arrow" src="/images/home/icon-arrow-right-dest.svg" mode="aspectFit" />
            </view>
          </view>
          <view class="esim-card__desc">
            <text>eSIM是</text>
            <text class="esim-card__emph">内嵌在手机里的数字SIM 卡</text>
            <text>。不用换卡、不用等快递，手机直接下载安装，</text>
            <text class="esim-card__emph">30秒激活</text>
            <text>。</text>
          </view>
        </view>

        <view class="esim-card__divider" />

        <view class="esim-card__section">
          <view class="esim-card__head">
            <text class="esim-card__title">使用方法</text>
            <view class="esim-card__link" bindtap="onUsageGuideTap">
              <text>查看完整教程</text>
              <image class="esim-card__arrow" src="/images/home/icon-arrow-right-dest.svg" mode="aspectFit" />
            </view>
          </view>
          <view class="usage-steps">
            <block wx:for="{{usageSteps}}" wx:key="id" wx:for-index="stepIndex">
              <view class="usage-step">
                <view class="usage-step__icon-wrap">
                  <image class="usage-step__icon" src="{{item.icon}}" mode="aspectFit" />
                </view>
                <text class="usage-step__label">{{item.label}}</text>
              </view>
              <view wx:if="{{stepIndex < usageSteps.length - 1}}" class="usage-steps__connector" />
            </block>
          </view>
          <view class="esim-compat-card" bindtap="onCompatCardTap">
            <view class="esim-compat-card__left">
              <image class="esim-compat-card__icon" src="/images/home/compat-check-icon.svg" mode="aspectFit" />
              <view class="esim-compat-card__text">
                <text class="esim-compat-card__name">我的设备支持吗？</text>
                <text class="esim-compat-card__desc">支持大陆版与国际版机型查询</text>
              </view>
            </view>
            <image class="esim-compat-card__arrow" src="/images/home/icon-arrow-right-dest.svg" mode="aspectFit" />
          </view>
        </view>
      </view>

      <view class="reviews-card">
        <view class="reviews-card__header">
          <view class="reviews-card__brand">
            <image class="reviews-card__logo" src="/images/home/trustpilot-logo.svg" mode="aspectFit" />
            <text class="reviews-card__count">来自 95,304 位用户评价</text>
          </view>
          <view class="reviews-card__rating">
            <text class="reviews-card__score">4.7</text>
            <text class="reviews-card__max">/5</text>
            <image class="reviews-card__arrow" src="/images/home/icon-arrow-right.svg" mode="aspectFit" />
          </view>
        </view>
        <view class="reviews-card__divider" />
        <scroll-view class="reviews-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="reviews-list">
            <view wx:for="{{reviews}}" wx:key="id" class="review-item">
              <view class="review-item__top">
                <text class="review-item__name">{{item.name}}</text>
                <view class="review-item__badge">
                  <text class="review-item__badge-text">{{item.rating}}</text>
                </view>
              </view>
              <text class="review-item__text">{{item.text}}</text>
              <text class="review-item__meta">{{item.meta}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>
  </scroll-view>

  <view
    class="compat-sheet-mask {{showCompatSheet ? 'compat-sheet-mask--show' : ''}}"
    bindtap="onCloseCompatSheet"
    catchtouchmove="noop"
  />
  <view
    class="compat-sheet {{showCompatSheet ? 'compat-sheet--show' : ''}}"
    style="padding-bottom: {{safeBottom + 24}}px;"
    catchtap="noop"
    catchtouchmove="noop"
  >
    <view class="compat-sheet__handle-wrap">
      <view class="compat-sheet__handle" />
    </view>
    <view class="compat-sheet__header">
      <text class="compat-sheet__title">检查我的手机是否支持 eSIM</text>
      <view class="compat-sheet__close" bindtap="onCloseCompatSheet" aria-label="关闭">
        <image class="compat-sheet__close-icon" src="/images/compat/close.svg" mode="aspectFit" />
      </view>
    </view>
    <view class="compat-sheet__section">
      <text class="compat-step-label">1. 您的手机是哪个版本</text>
      <view class="compat-version-row">
          <view
            wx:for="{{compatVersions}}"
            wx:key="id"
            class="compat-version compat-version--{{item.id}} {{compatVersion === item.id ? 'compat-version--active' : ''}}"
            data-version="{{item.id}}"
            bindtap="onCompatVersionTap"
          >
            <image class="compat-version__icon" src="{{item.icon}}" mode="aspectFill" />
            <view class="compat-version__text">
              <text class="compat-version__title">{{item.title}}</text>
              <text class="compat-version__subtitle">{{item.subtitle}}</text>
            </view>
          </view>
      </view>
    </view>
    <scroll-view class="compat-sheet__body" scroll-y enhanced show-scrollbar="{{false}}">
        <text class="compat-step-label">2. 选择查询方式</text>
        <view class="compat-segment">
          <view
            wx:for="{{compatMethods}}"
            wx:key="id"
            class="compat-segment__item {{compatMethod === item.id ? 'compat-segment__item--active' : ''}}"
            data-method="{{item.id}}"
            bindtap="onCompatMethodTap"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
        <view wx:if="{{compatMethod === 'model'}}" class="compat-model-panel">
          <view class="compat-search">
            <image class="compat-search__icon" src="/images/compat/search.svg" mode="aspectFit" />
            <input
              class="compat-search__input"
              placeholder="搜索手机品牌或型号"
              placeholder-class="compat-search__placeholder"
              value="{{compatSearch}}"
              bindinput="onCompatSearchInput"
            />
          </view>
          <view class="compat-models">
            <view class="compat-device-block">
              <text class="compat-sheet__label">您的机型</text>
              <view class="compat-model">
                <text class="compat-model__name">{{compatDevice.name}}</text>
                <view wx:if="{{compatDevice.supported}}" class="compat-model__badge">
                  <image class="compat-model__check" src="/images/compat/check.svg" mode="aspectFit" />
                  <text>支持</text>
                </view>
              </view>
            </view>
            <view class="compat-model__divider" />
            <text class="compat-sheet__label">热门机型</text>
            <block wx:for="{{filteredCompatModels}}" wx:key="id">
              <view class="compat-model">
                <text class="compat-model__name">{{item.name}}</text>
                <view wx:if="{{item.supported}}" class="compat-model__badge">
                  <image class="compat-model__check" src="/images/compat/check.svg" mode="aspectFit" />
                  <text>支持</text>
                </view>
              </view>
              <view wx:if="{{index < filteredCompatModels.length - 1}}" class="compat-model__divider" />
            </block>
          </view>
        </view>
        <view wx:else class="compat-dial">
          <view class="compat-dial__intro">
            <text class="compat-dial__intro-title">{{compatDialIntroTitle}}</text>
            <view class="compat-dial__intro-text">
              <text>在手机拨号界面输入 </text>
              <text class="compat-dial__code-inline">*#06#</text>
              <text> 如果屏幕列表中出现 EID 串号（约 32 位数字），则说明您的手机硬件支持 eSIM。</text>
            </view>
          </view>
          <image class="compat-dial__phones" src="/images/compat/dial-phones.png" mode="widthFix" />
          <view class="compat-dial__steps">
            <view wx:for="{{compatDialSteps}}" wx:key="title" class="compat-dial__step">
              <view class="compat-dial__step-num"><text>{{index + 1}}</text></view>
              <view class="compat-dial__step-body">
                <text class="compat-dial__step-title">{{item.title}}</text>
                <text class="compat-dial__step-desc">{{item.desc}}</text>
              </view>
            </view>
          </view>
          <view class="compat-dial__results">
            <view
              wx:for="{{compatDialResults}}"
              wx:key="id"
              class="compat-dial__result compat-dial__result--{{item.type}}"
              data-result="{{item.id}}"
              bindtap="onCompatDialResultTap"
            >
              <text class="compat-dial__result-title compat-dial__result-title--{{item.type}}">{{item.title}}</text>
              <text class="compat-dial__result-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
    </scroll-view>
  </view>
</view>
