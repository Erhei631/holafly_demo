<view class="checkout-page" style="padding-top: {{statusBarHeight}}px;">
  <view class="checkout-nav">
    <view class="checkout-nav__back" bindtap="onBack" aria-label="返回">
      <image class="checkout-nav__back-icon" src="/images/detail/nav-back.svg" mode="aspectFit" />
    </view>
    <text class="checkout-nav__title">确认订单</text>
    <view class="checkout-nav__right">
      <view class="nav-capsule nav-capsule--menu">
        <image class="nav-capsule__icon nav-capsule__icon--sm" src="/images/detail/nav-share.svg" mode="aspectFit" />
        <image class="nav-capsule__sep" src="/images/detail/nav-divider.svg" mode="aspectFit" />
        <image class="nav-capsule__icon nav-capsule__icon--sm" src="/images/detail/nav-close.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <scroll-view
    class="checkout-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    style="padding-bottom: calc(220rpx + {{safeBottom}}px);"
  >
    <view class="checkout-stack">
      <view class="checkout-panel">
        <text class="checkout-panel__title">订单摘要</text>
        <view class="checkout-summary">
          <view class="checkout-product">
            <view class="checkout-product__left">
              <image class="checkout-product__flag" src="{{productFlag}}" mode="aspectFill" />
              <text class="checkout-product__name">{{productTitle}}</text>
            </view>
            <view class="checkout-product__price">
              <view class="checkout-product__price-core">
                <text class="checkout-product__price-symbol">¥</text>
                <text class="checkout-product__price-amount">{{dailyAvgLabel}}</text>
              </view>
              <text class="checkout-product__price-unit">/天</text>
            </view>
          </view>
          <view class="checkout-row">
            <view class="checkout-row__left">
              <image class="checkout-row__icon" src="/images/detail/icon-calendar.svg" mode="aspectFit" />
              <text class="checkout-row__label">使用天数</text>
            </view>
            <text class="checkout-row__value">{{days}}天</text>
          </view>
          <view class="checkout-row">
            <view class="checkout-row__left">
              <image class="checkout-row__icon" src="/images/detail/icon-esim.svg" mode="aspectFit" />
              <text class="checkout-row__label">eSIM数量</text>
            </view>
            <text class="checkout-row__qty">× {{quantity}}</text>
          </view>
        </view>
      </view>

      <view class="checkout-promo {{promoApplied ? 'checkout-promo--applied' : ''}}">
        <block wx:if="{{!promoApplied}}">
          <view class="checkout-promo__copy">
            <text class="checkout-promo__title">输入折扣码</text>
            <text class="checkout-promo__desc">填写后将在订单中自动抵扣</text>
          </view>
          <view class="checkout-promo__field">
            <input
              class="checkout-promo__input"
              type="text"
              placeholder="请输入折扣码"
              placeholder-class="checkout-promo__placeholder"
              value="{{promoCode}}"
              bindinput="onPromoInput"
              confirm-type="done"
              bindconfirm="onApplyPromo"
            />
            <button class="checkout-promo__apply" bindtap="onApplyPromo" aria-label="使用折扣码">
              <image class="checkout-promo__apply-icon" src="/images/checkout/promo-apply-arrow.svg" mode="aspectFit" />
            </button>
          </view>
        </block>
        <view wx:else class="checkout-promo-success">
          <text class="checkout-promo-success__title">折扣码使用成功</text>
          <view class="checkout-promo-success__actions">
            <view class="checkout-promo-success__badge">
              <text class="checkout-promo-success__badge-text">{{promoDiscountLabel}}</text>
            </view>
            <view class="checkout-promo-success__close" bindtap="onRemovePromo" aria-label="移除折扣码">
              <image class="checkout-promo-success__close-icon" src="/images/checkout/promo-close-circle.svg" mode="aspectFit" />
            </view>
          </view>
        </view>
      </view>

      <view class="checkout-panel">
        <text class="checkout-panel__title">价格明细</text>
        <view class="checkout-price-list">
          <view class="checkout-price-row">
            <text class="checkout-price-row__label">商品总价</text>
            <text class="checkout-price-row__value">{{originalTotalLabel}}</text>
          </view>
          <view class="checkout-price-row">
            <text class="checkout-price-row__label">折扣码优惠</text>
            <text class="checkout-price-row__placeholder">{{discountLabel}}</text>
          </view>
        </view>
        <view class="checkout-divider" />
        <view class="checkout-price-row checkout-price-row--total">
          <text class="checkout-price-row__label checkout-price-row__label--strong">合计</text>
          <text class="checkout-price-row__total">{{totalPriceLabel}}</text>
        </view>
      </view>

      <view class="checkout-trust">
        <view class="checkout-trust__item">
          <image class="checkout-trust__icon" src="/images/checkout/trust-payment.svg" mode="aspectFit" />
          <text class="checkout-trust__text">支付保障</text>
        </view>
        <view class="checkout-trust__item">
          <image class="checkout-trust__icon" src="/images/checkout/trust-ssl.svg" mode="aspectFit" />
          <text class="checkout-trust__text">SSL 加密</text>
        </view>
        <view class="checkout-trust__item">
          <image class="checkout-trust__icon" src="/images/checkout/trust-refund.svg" mode="aspectFit" />
          <text class="checkout-trust__text">未激活可退</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="checkout-footer" style="padding-bottom: calc(16rpx + {{safeBottom}}px);">
    <button class="checkout-footer__pay btn-primary" bindtap="onConfirmPay">{{payLabel}}</button>
    <view class="checkout-agree" bindtap="onToggleAgree">
      <view class="checkout-agree__check {{agreed ? 'checkout-agree__check--on' : ''}}">
        <text wx:if="{{agreed}}" class="checkout-agree__tick">✓</text>
      </view>
      <text class="checkout-agree__text">
        <text>我已阅读并同意</text>
        <text class="checkout-agree__link">支付协议</text>
        <text>及</text>
        <text class="checkout-agree__link">购买须知</text>
      </text>
    </view>
  </view>
</view>
