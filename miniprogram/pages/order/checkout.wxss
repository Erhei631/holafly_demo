.checkout-page {
  min-height: 100vh;
  background: var(--color-bg-base);
  display: flex;
  flex-direction: column;
}

.checkout-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 14rpx;
  height: 88rpx;
  background: var(--color-bg-base);
}

.checkout-nav__back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkout-nav__back-icon {
  width: 18rpx;
  height: 33rpx;
}

.checkout-nav__title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.checkout-nav__right {
  width: 166rpx;
  display: flex;
  justify-content: flex-end;
}

.nav-capsule {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #dedede;
  border-radius: 30rpx;
}

.nav-capsule--menu {
  width: 166rpx;
  padding: 0 20rpx;
}

.nav-capsule__icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-capsule__icon--sm {
  width: 28rpx;
  height: 28rpx;
}

.nav-capsule__sep {
  width: 2rpx;
  height: 26rpx;
  margin: 0 16rpx;
}

.checkout-scroll {
  flex: 1;
  height: 0;
}

.checkout-stack {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 20rpx 40rpx 40rpx;
}

.checkout-panel {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 32rpx;
  background: var(--color-bg-base);
  border-radius: 48rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
}

.checkout-panel__title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.checkout-summary {
  padding: 24rpx 32rpx;
  background: var(--color-bg-muted);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.checkout-product {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 4rpx 0;
}

.checkout-product__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.checkout-product__flag {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.checkout-product__name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.checkout-product__price {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.checkout-product__price-core {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: var(--color-primary);
}

.checkout-product__price-symbol,
.checkout-product__price-amount {
  font-size: 32rpx;
  font-weight: 500;
  line-height: 48rpx;
}

.checkout-product__price-amount {
  font-size: 40rpx;
  line-height: 56rpx;
}

.checkout-product__price-unit {
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text-secondary);
}

.checkout-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 8rpx;
}

.checkout-row__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkout-row__icon {
  display: block;
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.checkout-row__label {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.checkout-row__value,
.checkout-row__qty {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.checkout-promo {
  position: relative;
  overflow: hidden;
  padding: 32rpx 22rpx;
  border-radius: 32rpx;
  background-image: url('/images/checkout/promo-bg.png');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-position: center;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.05);
}

.checkout-promo--applied {
  padding: 32rpx 22rpx;
  background-image: none;
  background: linear-gradient(150.19deg, var(--rose-50) 11.21%, #fff5ef 89.26%);
}

.checkout-promo__copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  max-width: 420rpx;
}

.checkout-promo__title {
  font-size: 32rpx;
  font-weight: 500;
  line-height: 48rpx;
  color: var(--color-text-primary);
}

.checkout-promo__desc {
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text-tertiary);
}

.checkout-promo__field {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0 16rpx 0 24rpx;
  height: 88rpx;
  background: var(--color-bg-base);
  border-radius: 20rpx;
}

.checkout-promo__input {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.checkout-promo__placeholder {
  color: var(--color-text-tertiary);
  font-weight: 400;
}

.checkout-promo__apply {
  width: 72rpx !important;
  height: 72rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #e6485c 0%, #f9733d 95.7%);
  border: none;
}

.checkout-promo__apply::after {
  border: none;
}

.checkout-promo__apply-icon {
  width: 32rpx;
  height: 32rpx;
}

.checkout-promo-success {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.checkout-promo-success__title {
  font-size: 32rpx;
  font-weight: 500;
  line-height: 48rpx;
  color: var(--color-text-primary);
}

.checkout-promo-success__actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-shrink: 0;
}

.checkout-promo-success__badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #e6485c 0%, #f9733d 95.7%);
}

.checkout-promo-success__badge-text {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 36rpx;
  color: #fff;
}

.checkout-promo-success__close {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.5;
}

.checkout-promo-success__close-icon {
  width: 32rpx;
  height: 32rpx;
}

.checkout-price-list {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.checkout-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.checkout-price-row__label {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  line-height: 44rpx;
}

.checkout-price-row__label--strong {
  color: var(--color-text-primary);
}

.checkout-price-row__value {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 48rpx;
}

.checkout-price-row__placeholder {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  line-height: 40rpx;
}

.checkout-divider {
  height: 1rpx;
  background: var(--color-border-base);
  margin: 32rpx 0 24rpx;
}

.checkout-price-row__total {
  font-size: 40rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 56rpx;
}

.checkout-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 0 8rpx;
}

.checkout-trust__item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.checkout-trust__icon {
  width: 26rpx;
  height: 26rpx;
}

.checkout-trust__text {
  font-size: 24rpx;
  line-height: 36rpx;
  color: var(--color-text-secondary);
}

.checkout-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 32rpx 40rpx 16rpx;
  background: rgba(248, 248, 248, 0.8);
  backdrop-filter: blur(30px);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.checkout-footer__pay {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #272729;
  box-shadow: 0 20rpx 40rpx rgba(57, 224, 57, 0.35);
}

.checkout-footer__pay::after {
  border: none;
}

.checkout-agree {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 12rpx;
  margin-top: 32rpx;
}

.checkout-agree__check {
  width: 36rpx;
  height: 36rpx;
  margin-top: 2rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border-base);
  background: var(--color-bg-base);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.checkout-agree__check--on {
  border-color: var(--color-primary);
  background: var(--color-primary);
}

.checkout-agree__tick {
  font-size: 22rpx;
  color: #fff;
  line-height: 1;
}

.checkout-agree__text {
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text-tertiary);
}

.checkout-agree__link {
  color: #0d8cc2;
}
