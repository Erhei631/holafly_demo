.page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  background: linear-gradient(
    180deg,
    var(--blue-100) 0%,
    var(--blue-50) 28%,
    var(--neutral-50) 62%
  );
  pointer-events: none;
}

.nav,
.hero,
.plan-swiper,
.footer {
  position: relative;
  z-index: 1;
}

.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-2) var(--space-4);
}

.nav__back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav__back-icon {
  font-size: var(--font-size-h3);
  font-weight: 300;
  line-height: 1;
  color: var(--color-text-primary);
}

.nav__brand {
  display: flex;
  align-items: baseline;
}

.nav__brand-holafly {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}

.nav__brand-plans {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-brand);
}

.nav__avatar {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-subtitle-2);
  background: rgba(255, 255, 255, 0.65);
  border-radius: var(--radius-full);
}

.hero {
  padding: var(--space-2) var(--space-4) var(--space-4);
  text-align: center;
}

.hero__title {
  display: block;
  font-size: var(--font-size-h3);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.hero__subtitle {
  display: block;
  margin-top: var(--space-2);
  font-size: var(--font-size-lg);
  font-weight: 500;
  color: var(--color-text-primary);
}

.hero__tagline {
  display: block;
  margin-top: var(--space-1);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.plan-swiper {
  flex: 1;
  width: 100%;
  min-height: 720rpx;
}

.plan-swiper__item {
  display: flex;
  align-items: stretch;
  padding: 0 var(--space-1);
  box-sizing: border-box;
}

.plan-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: var(--color-bg-base);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-soft-md);
  overflow: hidden;
}

.plan-card__head {
  padding: var(--space-4);
}

.plan-card__head--light {
  background: linear-gradient(145deg, var(--blue-200), var(--blue-50));
}

.plan-card__head--unlimited {
  background: linear-gradient(145deg, var(--blue-300), var(--rose-50));
}

.plan-card__popular {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: var(--space-2);
  padding: 6rpx 16rpx;
  background: var(--neutral-800);
  border-radius: var(--radius-full);
  font-size: var(--font-size-caption);
  color: var(--neutral-50);
}

.plan-card__popular-icon {
  font-size: var(--font-size-caption);
}

.plan-card__name {
  display: block;
  font-size: var(--font-size-subtitle-2);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.plan-card__promo {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-top: var(--space-2);
  padding: 8rpx 16rpx;
  background: var(--green-100);
  border-radius: var(--radius-full);
  font-size: var(--font-size-caption);
  color: var(--color-secondary-pressed);
}

.plan-card__promo-icon {
  font-size: var(--font-size-caption);
}

.plan-card__body {
  flex: 1;
  padding: var(--space-4);
}

.plan-card__headline {
  display: block;
  font-size: var(--font-size-h3);
  font-weight: 600;
  color: var(--color-text-primary);
}

.plan-card__services {
  display: block;
  margin-top: var(--space-2);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.plan-card__features {
  margin-top: var(--space-4);
}

.plan-card__feature {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
}

.plan-card__check {
  color: var(--color-secondary-hover);
  font-size: var(--font-size-base);
  font-weight: 700;
  line-height: 1.4;
}

.plan-card__feat-text {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: 1.45;
}

.plan-card__price-row {
  display: flex;
  align-items: baseline;
  margin-top: var(--space-5);
  padding-top: var(--space-4);
  border-top: 1rpx solid var(--color-divider);
}

.plan-card__price {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}

.plan-card__period {
  margin-left: 4rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.footer {
  padding: var(--space-3) var(--space-4) var(--space-4);
}

.footer__hint {
  display: block;
  margin-bottom: var(--space-2);
  text-align: center;
  font-size: var(--font-size-caption);
  color: var(--color-text-quaternary);
}

.footer__cta {
  width: 100% !important;
}
