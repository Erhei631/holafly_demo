@import './login-sms.wxss';

.verify-code {
  position: relative;
  width: 100%;
  margin-top: 78rpx;
  display: flex;
  gap: 16rpx;
}

.verify-code__box {
  flex: 1;
  min-width: 0;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-base);
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  font-size: 40rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  line-height: 56rpx;
  box-sizing: border-box;
}

.verify-code__box--filled,
.verify-code__box--active {
  border-color: var(--color-primary);
}

.verify-code__input {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  color: transparent;
  caret-color: transparent;
}

.login-actions--verify {
  margin-top: 68rpx;
  gap: 48rpx;
}

.verify-resend {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  line-height: 40rpx;
  text-align: center;
}

.verify-resend--link {
  color: var(--blue-600);
}

.login-btn--disabled {
  background: rgba(230, 72, 92, 0.4);
  box-shadow: 0 20rpx 80rpx rgba(230, 72, 92, 0.35);
}
