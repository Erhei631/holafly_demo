@import './login.wxss';

.login-body--sms {
  padding-left: 52rpx;
  padding-right: 52rpx;
}

.login-brand--sms {
  gap: 32rpx;
}

.login-brand__text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.login-brand__subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 40rpx;
  text-align: center;
}

.login-phone {
  width: 100%;
  margin-top: 78rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 24rpx 32rpx;
  background: var(--color-bg-base);
  border-radius: 20rpx;
  box-sizing: border-box;
}

.login-phone__code {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  line-height: 48rpx;
  flex-shrink: 0;
}

.login-phone__divider {
  width: 1rpx;
  height: 32rpx;
  background: var(--color-border-base);
  flex-shrink: 0;
}

.login-phone__input {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 44rpx;
}

.login-phone__placeholder {
  color: var(--color-text-tertiary);
}

.login-actions--sms {
  margin-top: 68rpx;
  gap: 48rpx;
}
