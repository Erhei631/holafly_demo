.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  background: rgba(248, 248, 248, 0.8);
  backdrop-filter: blur(30px);
  border-top: none;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.tab-bar__inner {
  display: flex;
  align-items: stretch;
  min-height: 112rpx;
  flex-shrink: 0;
}

.tab-bar__safe {
  flex-shrink: 0;
  width: 100%;
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  background: inherit;
}

.tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 16rpx 0 8rpx;
}

.tab-bar__icon-wrap {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-bar__icon {
  width: 34rpx;
  height: 38rpx;
}

.tab-bar__text {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
  line-height: 1.6;
}

.tab-bar__item--active .tab-bar__text {
  color: var(--color-primary);
  font-weight: 500;
}
