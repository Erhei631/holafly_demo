<view class="tab-bar">
  <view class="tab-bar__inner">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-bar__item {{selected === index ? 'tab-bar__item--active' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-bar__icon-wrap">
        <image
          class="tab-bar__icon"
          src="{{selected === index ? item.iconActive : item.icon}}"
          mode="aspectFit"
        />
      </view>
      <text class="tab-bar__text">{{item.text}}</text>
    </view>
  </view>
  <view class="tab-bar__safe" style="height: {{safeBottom}}px;"></view>
</view>
